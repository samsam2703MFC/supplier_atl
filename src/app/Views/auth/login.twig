<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ translations.supplier_portal_login_title }}</title>

    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ ROOT }}/assets/vendors/bootstrap-icons/bootstrap-icons.css">
    <link rel="stylesheet" href="{{ ROOT }}/assets/css/design-system.css">
    <link rel="stylesheet" href="{{ ROOT }}/assets/css/pages/auth.css">
</head>

<body>
<div class="dc-login">

    {# LEFT: Branding / Context #}
    <div class="dc-login__brand">
        <div class="dc-login__brand-inner">
            <img class="dc-login__logo" src="{{ ROOT }}/assets/images/atelierby-white.png" alt="L'Atelier by">

            <div class="dc-login__badge">
                <i class="bi bi-truck"></i>
                <span>{{ translations.supplier_app_external }}</span>
            </div>

            <h1 class="dc-login__title">{{ translations.supplier_panel }}</h1>
            <p class="dc-login__subtitle">{{ translations.supplier_panel_subtitle }}</p>

            <div class="dc-login__points">
                <div class="dc-login__point">
                    <i class="bi bi-shield-lock"></i>
                    <span>{{ translations.supplier_point_separate_auth }}</span>
                </div>
                <div class="dc-login__point">
                    <i class="bi bi-box-seam"></i>
                    <span>{{ translations.supplier_point_catalog }}</span>
                </div>
                <div class="dc-login__point">
                    <i class="bi bi-tags"></i>
                    <span>{{ translations.supplier_point_price_lists }}</span>
                </div>
            </div>

            <div class="dc-login__hint">{{ translations.supplier_no_access_hint }}</div>
        </div>
    </div>

    {# RIGHT: Login form #}
    <div class="dc-login__auth">
        <div class="dc-login__card">
            <div class="dc-login__card-head">
                <div>
                    <h2 class="dc-login__card-title">{{ translations.login }}</h2>
                    <p class="t-label dc-login__card-sub">{{ translations.login_to_supplier_panel }}</p>
                </div>
                <span class="dc-login__chip">
                    <i class="bi bi-grid-1x2-fill"></i>
                    <span>{{ translations.supplier_portal_label }}</span>
                </span>
            </div>

            <div class="dc-login__divider"></div>

            {% if errors.invalid_credentials is not empty %}
                <div class="dc-login__alert">
                    <i class="bi bi-exclamation-triangle"></i>
                    <span>{{ errors.invalid_credentials }}</span>
                </div>
            {% endif %}

            <form method="POST" autocomplete="on" class="dc-login__form">
                <div class="dc-login__field">
                    <i class="bi bi-person dc-login__field-icon"></i>
                    <input
                            type="text"
                            class="dc-login__input {{ errors.login is not empty ? 'is-invalid' : '' }}"
                            name="login"
                            placeholder="{{ translations.login_placeholder }}"
                            inputmode="text"
                            autocomplete="username"
                            autocapitalize="none"
                            spellcheck="false"
                            value="{{ old('login') }}"
                    >
                </div>
                {% if errors.login is not empty %}
                    <div class="dc-login__error">{{ errors.login }}</div>
                {% endif %}

                <div class="dc-login__field">
                    <i class="bi bi-shield-lock dc-login__field-icon"></i>
                    <input
                            type="password"
                            class="dc-login__input {{ errors.password is not empty ? 'is-invalid' : '' }}"
                            name="password"
                            placeholder="{{ translations.password_placeholder }}"
                            autocomplete="current-password"
                    >
                </div>
                {% if errors.password is not empty %}
                    <div class="dc-login__error">{{ errors.password }}</div>
                {% endif %}

                <button type="submit" class="dc-login__submit">
                    <i class="bi bi-box-arrow-in-right"></i>
                    <span>{{ translations.login_button }}</span>
                </button>

                <div class="t-label dc-login__form-hint">{{ translations.login_help_hint }}</div>
            </form>

            <div class="t-label dc-login__copy">
                © {{ "now"|date("Y") }} · {{ translations.franchise_ecosystem }} · {{ translations.supplier_panel }}
            </div>
        </div>
    </div>

</div>
</body>
</html>
