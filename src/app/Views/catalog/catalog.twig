{% extends "layouts/base.twig" %}

{% block title %}{{ translations.catalog_products }}{% endblock %}

{% block head %}
<link rel="stylesheet" href="{{ ROOT }}/assets/css/cropper/cropper.min.css">
<style>
.products-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:14px;margin-bottom:8px;}
.product-card{background:#fff;border-radius:10px;border:1.5px solid #E2E8F0;overflow:hidden;transition:all .2s;position:relative;}
.product-card:hover{box-shadow:0 8px 24px rgba(15,23,42,.1);transform:translateY(-2px);border-color:#6366F1;}
.product-img{height:140px;background:#F8FAFC;position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center;}
.product-img .no-img{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;color:#94A3B8;font-size:11px;width:100%;height:100%;}
.pc-overlay{position:absolute;inset:0;background:rgba(15,23,42,.55);display:flex;align-items:center;justify-content:center;gap:8px;opacity:0;transition:opacity .18s;}
.product-card:hover .pc-overlay{opacity:1;}
.pc-act-btn{width:36px;height:36px;border-radius:8px;border:none;background:rgba(255,255,255,.92);color:#0F172A;font-size:15px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .12s;}
.pc-act-btn:hover{background:#fff;transform:scale(1.1);}
.product-info{padding:12px;}
.product-name{font-size:13px;font-weight:600;color:#0F172A;margin-bottom:2px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;line-height:1.35;}
.product-ref{font-size:11px;color:#64748B;margin-bottom:2px;}
.product-meta{display:flex;flex-wrap:wrap;gap:4px;margin-top:4px;}
.pc-badge{display:inline-block;padding:1px 7px;border-radius:4px;font-size:10.5px;background:#F1F5F9;color:#475569;}
.pc-pill{flex-shrink:0;display:inline-block;padding:2px 8px;border-radius:20px;font-size:10px;font-weight:600;white-space:nowrap;}
.pc-pill-active{background:#DCFCE7;color:#15803D;}
.pc-pill-inactive{background:#F1F5F9;color:#94A3B8;}
.pc-allergens{margin-top:6px;}
.pg-empty{grid-column:1/-1;text-align:center;padding:48px 16px;color:#94A3B8;display:flex;flex-direction:column;align-items:center;gap:8px;font-size:13px;}
.pg-empty i{font-size:32px;opacity:.4;}
/* Photo modal */
#photoModal .photo-preview-wrap{background:#F8FAFC;border-radius:8px;min-height:200px;display:flex;align-items:center;justify-content:center;overflow:hidden;margin-bottom:12px;}
#photoModal .photo-preview-wrap img{max-width:100%;max-height:300px;object-fit:contain;}
#photoModal .photo-no-img{display:flex;flex-direction:column;align-items:center;gap:8px;color:#94A3B8;padding:40px 0;}
#photoModal .photo-no-img i{font-size:40px;opacity:.35;}
#crop-container-photo{max-height:340px;overflow:hidden;}
#crop-container-photo img{display:block;max-width:100%;}
</style>
{% endblock %}

{% block page_heading %}
    <div class="page-heading">
        <h3>{{ translations.catalog_products }}</h3>
        <p class="text-subtitle text-muted">{{ translations.catalog_products_subtitle }}</p>
    </div>
{% endblock %}

{% block content %}

    {% include "page_components/alerts.twig" %}

    <div class="row">
        <div class="col-12">

            {# QUICK HELP #}
            <div class="alert alert-light-primary d-flex align-items-start gap-2">
                <i class="bi bi-info-circle mt-1"></i>
                <div>
                    <div class="fw-bold">{{ translations.catalog_help_title }}</div>
                    <div class="small">
                        {{ translations.catalog_help_body }}
                    </div>
                </div>
            </div>

            {# INACTIVE MAPPED PRODUCTS INFO #}
            <div class="alert alert-warning d-flex align-items-start gap-2">
                <i class="bi bi-exclamation-triangle mt-1"></i>
                <div>
                    <div class="fw-bold">{{ translations.catalog_inactive_mapped_info_title }}</div>
                    <div class="small">
                        {{ translations.catalog_inactive_mapped_info_body }}
                    </div>
                </div>
            </div>

            {# TOOLBAR #}
            <div class="card">
                <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
                    <div>
                        <h4 class="card-title mb-0">{{ translations.products_table }}</h4>
                        <div class="text-muted small">{{ translations.products_table_hint }}</div>
                    </div>

                    <div class="d-flex gap-2 flex-wrap">
                        <button class="btn btn-primary" id="btnAddProduct">
                            <i class="bi bi-plus-lg me-1"></i>{{ translations.add_product }}
                        </button>
                        <button class="btn btn-outline-success" id="btnImportProducts">
                            <i class="bi bi-upload me-1"></i>{{ translations.import_products }}
                        </button>
                    </div>
                </div>

                <div class="card-body">

                    <div class="row g-2 align-items-end mb-3">
                        <div class="col-12 col-md-8">
                            <label class="form-label">{{ translations.filter_and_search }}</label>

                            <div class="d-flex flex-column flex-md-row gap-2">
                                <input id="filterSearch"
                                       type="text"
                                       class="form-control"
                                       placeholder="{{ translations.search_placeholder }}">

                                <button class="btn btn-light" id="btnClearFilters" type="button" style="white-space: nowrap;">
                                    <i class="bi bi-x-circle me-1"></i>{{ translations.clear_filters }}
                                </button>
                            </div>

                            <div class="form-text">
                                {{ translations.search_hint }}
                            </div>
                        </div>

                        <div class="col-12 col-md-4">
                            <label class="form-label">{{ translations.status|default('Status') }}</label>
                            <select id="filterStatus" class="form-select">
                                <option value="all">{{ translations.all|default('All') }}</option>
                                <option value="active" selected>{{ translations.active }}</option>
                                <option value="inactive">{{ translations.inactive }}</option>
                            </select>
                            <div class="form-text">
                                {{ translations.filter_by_status|default('Filter by product status') }}
                            </div>
                        </div>
                    </div>

                    <div id="productsGrid" class="products-grid">
                        <div class="pg-empty"><i class="bi bi-hourglass-split"></i><span>{{ translations.loading }}</span></div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <div class="small text-muted" id="tableMeta">{{ translations.table_meta_default }}</div>
                        <div class="small text-muted">
                            {{ translations.ajax_hint }}
                        </div>
                    </div>

                </div>
            </div>

        </div>
    </div>

    {# MODAL: ADD/EDIT PRODUCT #}
    {% include "catalog/modals/product_manage.twig" %}

    {# MODAL: ALLERGENS #}
    {% include "catalog/modals/allergen.twig" %}

    {# MODAL: PRODUCT SPECIFICATION (multilingual) #}
    {% include "catalog/modals/product_specification.twig" %}

    {# MODAL: IMPORT PRODUCTS #}
    {% include "catalog/modals/product_import.twig" %}

    {# MODAL: PHOTO MANAGEMENT #}
    <div class="modal fade" id="photoModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-camera me-2"></i>
                        <span id="photoModalTitle">{{ translations.catalog_photo_manage|default('Zdjęcie produktu') }}</span>
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">

                    {# -- Widok: podgląd obecnego zdjęcia -- #}
                    <div id="photoViewMode">
                        <div class="photo-preview-wrap" id="photoPreviewWrap">
                            <img id="photoCurrentImg" src="" alt="" style="display:none;">
                            <div class="photo-no-img" id="photoNoImgPlaceholder">
                                <i class="bi bi-image"></i>
                                <span class="small text-muted">{{ translations.catalog_no_photo|default('Brak zdjęcia') }}</span>
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <label class="btn btn-primary mb-0">
                                <i class="bi bi-upload me-1"></i>
                                {{ translations.catalog_photo_upload_new|default('Wgraj zdjęcie') }}
                                <input type="file" id="photoFileInput" accept="image/*" style="display:none">
                            </label>
                            <button type="button" class="btn btn-outline-danger" id="btnDeletePhoto" style="display:none">
                                <i class="bi bi-trash me-1"></i>
                                {{ translations.catalog_photo_delete|default('Usuń zdjęcie') }}
                            </button>
                        </div>
                    </div>

                    {# -- Widok: kadrowanie -- #}
                    <div id="photoCropMode" style="display:none;">
                        <div id="crop-container-photo">
                            <img id="photoCropImg" style="max-width:100%;">
                        </div>
                        <div class="d-flex gap-2 mt-3">
                            <button type="button" class="btn btn-success" id="btnCropSave">
                                <i class="bi bi-check-lg me-1"></i>
                                {{ translations.catalog_photo_crop_save|default('Przytnij i zapisz') }}
                            </button>
                            <button type="button" class="btn btn-outline-secondary" id="btnCropCancel">
                                {{ translations.cancel|default('Anuluj') }}
                            </button>
                        </div>
                    </div>

                </div>
                <div class="modal-footer" id="photoModalFooter">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">
                        {{ translations.close|default('Zamknij') }}
                    </button>
                </div>
            </div>
        </div>
    </div>

{% endblock %}

{% block scripts %}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const el = (id) => document.getElementById(id);

            function escapeHtml(s) {
                return String(s ?? "").replace(/[&<>"']/g, m => ({
                    "&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#039;"
                }[m]));
            }

            function badge(text, cls = "bg-light-secondary text-dark") {
                if (!text) return "";
                return `<span class="badge ${cls} me-1 mb-1">${escapeHtml(text)}</span>`;
            }

            function allergensToText(allergens) {
                if (!Array.isArray(allergens)) return "";
                return allergens
                    .map(a => (a?.name || a?.code || ""))
                    .filter(Boolean)
                    .join(" ");
            }

            function renderAllergensBadges(allergens) {
                const list = Array.isArray(allergens) ? allergens : [];
                if (!list.length) return `<span class="text-muted small">—</span>`;

                const max = 3;
                const shown = list.slice(0, max);
                const rest = list.length - shown.length;

                const badges = shown
                    .map(a => badge(a.name || a.code, "bg-light-warning text-dark"))
                    .join("");

                const more = rest > 0 ? badge(`+${rest}`, "bg-light text-muted") : "";

                // tooltip z pełną listą (ładniej, bo nie trzeba wszystkiego wyświetlać)
                const full = escapeHtml(list.map(a => a.name || a.code).join(", "));
                return `<span title="${full}">${badges}${more}</span>`;
            }


            // Lista alergenów z backendu (przekazana do widoku)
            window.ALLERGENS = {{ allergens|json_encode|raw }};
            // Nazwa dostawcy do generowania sugestii SKU
            window.SUPPLIER_NAME = {{ supplierName|default('')|json_encode|raw }};
            // =========================
            // State + modale
            // =========================
            const state = {
                products: [],
                loading: false,
                modalMode: 'add', // add | edit
                editId: null
            };

            const productModal   = new bootstrap.Modal(el("productModal"));
            const allergensModal = new bootstrap.Modal(el("allergensModal"));

            function setLoading(isLoading) {
                state.loading = isLoading;
                el("btnAddProduct").disabled = isLoading;
            }

            // =========================
            // Walidacja UI
            // =========================
            function clearErrors() {
                const ids = ["errSku","errName","errPackageQty","errPackageUnit","errWeightGrams","errShelfLifeDays","errVatRate"];
                ids.forEach(i => { el(i).textContent = ""; });

                ["productSku","productName","productPackageSize","productPackageUnit","productWeightGrams","productShelfLifeDays","productVatRate"].forEach(i => {
                    el(i).classList.remove("is-invalid");
                });
            }

            function applyErrors(errors) {
                const map = {
                    sku: ["productSku","errSku"],
                    name: ["productName","errName"],
                    package_size: ["productPackageSize","errPackageQty"],
                    package_unit: ["productPackageUnit","errPackageUnit"],
                    weight_grams: ["productWeightGrams","errWeightGrams"],
                    shelf_life_days: ["productShelfLifeDays","errShelfLifeDays"],
                    vat_rate: ["productVatRate","errVatRate"]
                };

                Object.keys(errors || {}).forEach(k => {
                    if (!map[k]) return;
                    const [inputId, errId] = map[k];
                    el(inputId).classList.add("is-invalid");
                    el(errId).textContent = errors[k];
                });
            }

            // =========================
            // Render tabeli
            // =========================
            function getFilteredProducts() {
                const q = (el("filterSearch").value || "").trim().toLowerCase();
                const statusFilter = el("filterStatus").value;

                return state.products.filter(p => {

                    const pkg = `${p.package_size ?? ""} ${p.package_unit ?? ""}`.trim();
                    const allergensText = allergensToText(p.allergens);

                    const hay = `${p.sku||""} ${p.name||""} ${allergensText} ${pkg}`.toLowerCase();

                    const matchQ = !q || hay.includes(q);

                    // Filtrowanie po statusie
                    let matchStatus = true;
                    if (statusFilter === 'active') {
                        matchStatus = (p.active !== 0 && p.active !== false && p.active !== null);
                    } else if (statusFilter === 'inactive') {
                        matchStatus = (p.active === 0 || p.active === false || p.active === null);
                    }
                    // dla 'all' matchStatus pozostaje true

                    return matchQ && matchStatus;
                });
            }

            function renderGrid() {
                const grid = el("productsGrid");
                const rows = getFilteredProducts();

                const tLoading   = {{ translations.loading|json_encode|raw }};
                const tNoResults = {{ translations.no_results|json_encode|raw }};
                const tNoPhoto   = {{ translations.catalog_no_photo|default('Brak zdjęcia')|json_encode|raw }};
                const tActive    = {{ translations.active|json_encode|raw }};
                const tInactive  = {{ translations.inactive|json_encode|raw }};
                const tEdit      = {{ translations.edit|json_encode|raw }};
                const tAllergens = {{ translations.allergens|json_encode|raw }};
                const tSpec      = {{ translations.specification|default('Specification')|json_encode|raw }};
                const tUploadPhoto = {{ translations.catalog_upload_photo|default('Dodaj zdjęcie')|json_encode|raw }};

                if (state.loading) {
                    grid.innerHTML = `<div class="pg-empty"><i class="bi bi-hourglass-split"></i><span>${escapeHtml(tLoading)}</span></div>`;
                    return;
                }

                if (!rows.length) {
                    grid.innerHTML = `<div class="pg-empty"><i class="bi bi-box"></i><span>${escapeHtml(tNoResults)}</span></div>`;
                    el("tableMeta").textContent = {{ translations.table_meta_empty|json_encode|raw }};
                    return;
                }

                grid.innerHTML = rows.map(p => {
                    const sku    = (p.sku || "").trim();
                    const name   = (p.name || "").trim();
                    const active = !(p.active === 0 || p.active === false || p.active === null);
                    const pkgQty  = p.package_size ?? "";
                    const pkgUnit = p.package_unit ?? "";
                    const pkgText = (pkgQty || pkgUnit) ? `${pkgQty} ${pkgUnit}`.trim() : "";
                    const hasAllergens = Array.isArray(p.allergens) && p.allergens.length > 0;

                    const hasPhoto = p.photo_url ? true : false;
    return `<div class="product-card" data-id="${escapeHtml(String(p.id))}">
  <div class="product-img">
    ${hasPhoto ? `<img src="${escapeHtml(p.photo_url)}" alt="${escapeHtml(name)}" style="width:100%;height:100%;object-fit:cover;" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">` : ''}
    <div class="no-img" style="${hasPhoto ? 'display:none' : ''}">
      <i class="bi bi-camera fs-2 opacity-25"></i>
      <small>${escapeHtml(tNoPhoto)}</small>
    </div>
    <div class="pc-overlay">
      <button class="pc-act-btn btn-upload-photo" title="${escapeHtml(tUploadPhoto)}" type="button"><i class="bi bi-camera-fill"></i></button>
      <button class="pc-act-btn btn-edit" title="${escapeHtml(tEdit)}" type="button"><i class="bi bi-pencil-fill"></i></button>
      <button class="pc-act-btn btn-allergens" title="${escapeHtml(tAllergens)}" type="button"><i class="bi bi-shield-check"></i></button>
      <button class="pc-act-btn btn-specification" title="${escapeHtml(tSpec)}" type="button"><i class="bi bi-list-check"></i></button>
    </div>
  </div>
  <div class="product-info">
    <div class="d-flex align-items-start justify-content-between gap-1 mb-1">
      <div class="product-name">${escapeHtml(name)}</div>
      <span class="pc-pill ${active ? 'pc-pill-active' : 'pc-pill-inactive'}">${active ? escapeHtml(tActive) : escapeHtml(tInactive)}</span>
    </div>
    ${sku ? `<div class="product-ref"><code style="font-size:10px">${escapeHtml(sku)}</code></div>` : ''}
    ${(pkgText || p.weight_grams || p.shelf_life_days) ? `<div class="product-meta">
      ${pkgText ? `<span class="pc-badge">${escapeHtml(pkgText)}</span>` : ''}
      ${p.weight_grams ? `<span class="pc-badge">${escapeHtml(String(p.weight_grams) + (p.weight_unit || 'g'))}</span>` : ''}
      ${p.shelf_life_days ? `<span class="pc-badge">${escapeHtml(String(p.shelf_life_days) + 'd')}</span>` : ''}
    </div>` : ''}
    ${hasAllergens ? `<div class="pc-allergens">${renderAllergensBadges(p.allergens)}</div>` : ''}
  </div>
</div>`;
                }).join("");

                const singular = {{ translations.item_singular|json_encode|raw }};
                const plural   = {{ translations.item_plural|json_encode|raw }};
                el("tableMeta").textContent = `${rows.length} ${rows.length === 1 ? singular : plural}`;
            }

            function getProductByCard(card) {
                const id = card?.getAttribute("data-id");
                return state.products.find(p => String(p.id) === String(id));
            }

            // =========================
            // Data loading (GET)
            // =========================
            async function loadProducts() {
                setLoading(true);
                renderGrid();

                try {
                    const params = new URLSearchParams("include=allergens,specification_multilingual,preparation_info");

                    const url = "/ajax/catalog/products" + (params.toString() ? ("?" + params.toString()) : "");
                    const resp = await api(url, { method: "GET" });

                    if (resp.success || resp.ok) {
                        state.products = resp.data || [];
                    } else {
                        state.products = [];
                        Swal.fire({
                            icon: 'error',
                            title: {{ translations.error|json_encode|raw }},
                            text: resp.message || {{ translations.undefined_error_occurred|json_encode|raw }}
                        });
                    }
                } catch (err) {
                    console.error(err);
                    Swal.fire({
                        icon: 'error',
                        title: {{ translations.error|json_encode|raw }},
                        text: {{ translations.no_api_connection|json_encode|raw }}
                    });
                } finally {
                    setLoading(false);
                    renderGrid();
                }
            }

            // =========================
            // Modal open / fill
            // =========================
            function generateSkuSuggestion() {
                const name = (window.SUPPLIER_NAME || '').trim();
                // Wyodrębnij inicjały z nazwy: bierz pierwsze litery słów o długości > 1,
                // pomijając typowe człony prawne (sp, z, o.o., ltd, sa, bv itp.)
                const skipWords = new Set(['sp', 'z', 'oo', 'o.o.', 'ltd', 'sa', 's.a.', 'srl', 'gmbh', 'bv', 'nv', 'inc', 'co', 'spolka', 'spółka']);
                const words = name.split(/[\s.,&/\\]+/).filter(w => w.length > 1 && !skipWords.has(w.toLowerCase()));
                const prefix = words.slice(0, 3).map(w => w[0].toUpperCase()).join('') || 'P';
                const num = String(state.products.length + 1).padStart(3, '0');
                return prefix + '-' + num;
            }

            function openCreateModal() {
                state.modalMode = 'add';
                state.editId = null;

                clearErrors();
                el("productId").value = "";
                el("productModalTitle").textContent = {{ translations.add_product|json_encode|raw }};
                el("modalMeta").textContent = {{ translations.modal_meta_new|json_encode|raw }};


                // Podstawowe pola (STARE)
                el("productSku").value = generateSkuSuggestion();
                el("productName").value = "";
                el("productPackageSize").value = "";
                el("productPackageUnit").value = "pcs";
                el("productVatRate").value = "0";

                // NOWE pola - podstawowe
                el("productActive").checked = true;
                el("productWeightGrams").value = "";
                el("productWeightUnit").value = "g";
                el("productShelfLifeDays").value = "";

                productModal.show();
            }

            function openEditModal(product) {
                state.modalMode = 'edit';
                state.editId = product.id;

                clearErrors();
                el("productId").value = product.id;
                el("productModalTitle").textContent = {{ translations.edit_product|json_encode|raw }};
                el("modalMeta").textContent = {{ translations.modal_meta_edit|json_encode|raw }} + ": #" + product.id;


                // Podstawowe pola (STARE)
                el("productSku").value = product.sku ?? "";
                el("productName").value = product.name ?? "";
                el("productPackageSize").value = product.package_size ?? "";
                el("productPackageUnit").value = product.package_unit ?? "pcs";
                el("productVatRate").value = product.vat_rate ?? "0";

                // NOWE pola - podstawowe
                el("productActive").checked = (product.active !== 0 && product.active !== false && product.active !== null);
                el("productWeightGrams").value = product.weight_grams ?? "";
                el("productWeightUnit").value = product.weight_unit ?? "g";
                el("productShelfLifeDays").value = product.shelf_life_days ?? "";

                productModal.show();
            }

            // =========================
            // Save (POST/PUT)
            // =========================
            async function saveProduct() {
                clearErrors();

                const payload = {
                    // STARE pola
                    sku: (el("productSku").value || "").trim(),
                    name: (el("productName").value || "").trim(),
                    package_size: el("productPackageSize").value ? Number(el("productPackageSize").value) : null,
                    package_unit: el("productPackageUnit").value || "pcs",
                    vat_rate: el("productVatRate").value || "0",

                    // NOWE pola
                    // API expects numeric active flag; send 1 for true, 0 for false
                    is_active: el("productActive").checked ? 1 : 0,
                    weight_grams: el("productWeightGrams").value ? Number(el("productWeightGrams").value) : null,
                    weight_unit: el("productWeightUnit").value || "g",
                    shelf_life_days: el("productShelfLifeDays").value ? Number(el("productShelfLifeDays").value) : null
                };

                // Walidacja podstawowa
                const errors = {};
                if (!payload.sku) errors.sku = {{ translations.field_required|json_encode|raw }};
                if (!payload.name) errors.name = {{ translations.field_required|json_encode|raw }};
                if (!payload.package_size) errors.package_size = {{ translations.field_required|json_encode|raw }};
                if (!payload.package_unit) errors.package_unit = {{ translations.field_required|json_encode|raw }};

                // Walidacja nowych pól
                if (payload.weight_grams !== null && payload.weight_grams <= 0) {
                    errors.weight_grams = "Waga musi być większa od 0";
                }
                if (payload.shelf_life_days !== null && payload.shelf_life_days <= 0) {
                    errors.shelf_life_days = "Termin przydatności musi być większy od 0";
                }

                if (Object.keys(errors).length) {
                    applyErrors(errors);
                    return;
                }

                el("btnSaveProduct").disabled = true;

                try {
                    let url = "/ajax/catalog/products";
                    let method = "POST";

                    if (state.modalMode === "edit") {
