            // =========================
            // Bind events
            // =========================
            function bindEvents() {
                el("btnAddProduct").addEventListener("click", openCreateModal);
                el("btnImportProducts").addEventListener("click", openImportModal);

                el("btnClearFilters").addEventListener("click", async () => {
                    el("filterSearch").value = "";
                    el("filterStatus").value = "all";
                    renderGrid();
                });

                el("filterSearch").addEventListener("input", () => renderGrid());
                el("filterStatus").addEventListener("change", () => renderGrid());

                el("btnSaveProduct").addEventListener("click", saveProduct);

                // Import modal events
                el("importFileInput").addEventListener("change", handleFileSelect);
                el("btnStartImport").addEventListener("click", startImport);

                // ==========================
                // Photo modal
                // ==========================
                const photoModal     = new bootstrap.Modal(el('photoModal'));
                const SwalToast = Swal.mixin({
                    toast: true, position: 'top-end',
                    showConfirmButton: false, timer: 3000, timerProgressBar: true,
                });

                let _photoProductId  = null;   // ID produktu otwartego w modalu
                let _photoCropper    = null;    // aktywna instancja Croppera

                function openPhotoModal(product) {
                    _photoProductId = product.id;
                    el('photoModalTitle').textContent = product.name || {{ translations.catalog_photo_manage|default('Zdjęcie produktu')|json_encode|raw }};

                    // reset — pokaż widok podglądu
                    _showPhotoViewMode();

                    const hasPhoto = !!product.photo_url;
                    const img      = el('photoCurrentImg');
                    const noImg    = el('photoNoImgPlaceholder');
                    const delBtn   = el('btnDeletePhoto');

                    if (hasPhoto) {
                        img.src = product.photo_url;
                        img.style.display = '';
                        noImg.style.display = 'none';
                        delBtn.style.display = '';
                    } else {
                        img.src = '';
                        img.style.display = 'none';
                        noImg.style.display = '';
                        delBtn.style.display = 'none';
                    }

                    photoModal.show();
                }

                function _showPhotoViewMode() {
                    el('photoViewMode').style.display  = '';
                    el('photoCropMode').style.display  = 'none';
                    if (_photoCropper) { _photoCropper.destroy(); _photoCropper = null; }
                }

                function _showPhotoCropMode(dataUrl) {
                    el('photoViewMode').style.display = 'none';
                    el('photoCropMode').style.display = '';

                    const cropImg = el('photoCropImg');
                    cropImg.src   = dataUrl;

                    // Inicjalizuj Cropper po wyrenderowaniu obrazu
                    if (_photoCropper) { _photoCropper.destroy(); _photoCropper = null; }
                    _photoCropper = new Cropper(cropImg, {
                        aspectRatio: 1,
                        viewMode: 1,
                        autoCropArea: 1,
                        responsive: true,
                    });
                }

                // Wybór pliku → podgląd w cropperze
                el('photoFileInput').addEventListener('change', (ev) => {
                    const file = ev.target.files[0];
                    ev.target.value = '';
                    if (!file) return;

                    const reader = new FileReader();
                    reader.onload = (e) => _showPhotoCropMode(e.target.result);
                    reader.readAsDataURL(file);
                });

                // Anuluj kadrowanie
                el('btnCropCancel').addEventListener('click', _showPhotoViewMode);

                // Zapisz po kadrowania → upload na serwer
                el('btnCropSave').addEventListener('click', () => {
                    if (!_photoCropper) return;

                    _photoCropper.getCroppedCanvas({ maxWidth: 1200, maxHeight: 1200 }).toBlob((blob) => {
                        const productId = _photoProductId;

                        Swal.fire({
                            title: {{ translations.catalog_photo_uploading|default('Przesyłanie zdjęcia...')|json_encode|raw }},
                            allowOutsideClick: false, allowEscapeKey: false,
                            showConfirmButton: false,
                            didOpen: () => {
                                Swal.showLoading();
                                const formData = new FormData();
                                formData.append('photo', blob, 'photo.jpg');

                                api(`/ajax/catalog/products/${productId}/photo`, { method: 'POST', data: formData })
                                    .then(resp => {
                                        Swal.close();
                                        if (resp.success && resp.photo_url) {
                                            const p = state.products.find(x => String(x.id) === String(productId));
                                            if (p) p.photo_url = resp.photo_url;
                                            renderGrid();
                                            photoModal.hide();
                                            SwalToast.fire({ icon: 'success', title: {{ translations.catalog_photo_uploaded|default('Zdjęcie zostało zapisane')|json_encode|raw }} });
                                        } else {
                                            SwalToast.fire({ icon: 'error', title: resp.message || {{ translations.undefined_error_occurred|json_encode|raw }} });
                                        }
                                    })
                                    .catch(err => {
                                        console.error(err);
                                        Swal.close();
                                        SwalToast.fire({ icon: 'error', title: {{ translations.no_api_connection|json_encode|raw }} });
                                    });
                            },
                        });
                    }, 'image/jpeg', 0.92);
                });

                // Usuń zdjęcie
                el('btnDeletePhoto').addEventListener('click', async () => {
                    const productId = _photoProductId;

                    const confirmed = await Swal.fire({
                        icon: 'warning',
                        title: {{ translations.catalog_photo_delete_confirm|default('Usunąć zdjęcie?')|json_encode|raw }},
                        showCancelButton: true,
                        confirmButtonColor: '#EF4444',
                        confirmButtonText: {{ translations.delete|default('Usuń')|json_encode|raw }},
                        cancelButtonText: {{ translations.cancel|default('Anuluj')|json_encode|raw }},
                    });
                    if (!confirmed.isConfirmed) return;

                    try {
                        const resp = await api(`/ajax/catalog/products/${productId}/photo`, { method: 'DELETE' });
                        if (resp.success) {
                            const p = state.products.find(x => String(x.id) === String(productId));
                            if (p) p.photo_url = null;
                            renderGrid();
                            photoModal.hide();
                            SwalToast.fire({ icon: 'success', title: {{ translations.catalog_photo_deleted|default('Zdjęcie zostało usunięte')|json_encode|raw }} });
                        } else {
                            SwalToast.fire({ icon: 'error', title: resp.message || {{ translations.undefined_error_occurred|json_encode|raw }} });
                        }
                    } catch (err) {
                        console.error(err);
                        SwalToast.fire({ icon: 'error', title: {{ translations.no_api_connection|json_encode|raw }} });
                    }
                });

                // Wyczyść cropper przy zamknięciu modala
                el('photoModal').addEventListener('hidden.bs.modal', () => {
                    if (_photoCropper) { _photoCropper.destroy(); _photoCropper = null; }
                    el('photoFileInput').value = '';
                    _showPhotoViewMode();
                });

                // akcje w tabeli
                el("productsGrid").addEventListener("click", (ev) => {
                    const card = ev.target.closest(".product-card");
                    if (!card) return;

                    const product = getProductByCard(card);
                    if (!product) return;

                    if (ev.target.closest(".btn-upload-photo")) { openPhotoModal(product); return; }
                    if (ev.target.closest(".btn-edit")) return openEditModal(product);
                    if (ev.target.closest(".btn-delete")) return confirmDelete(product);
                    if (ev.target.closest(".btn-allergens")) return openAllergensModal(product);
                    if (ev.target.closest(".btn-specification")) return openSpecificationModal(product);
                });

                // filtr wyszukiwania w modalu alergenów
                el("allergensSearch").addEventListener("input", () => {
                    const pid = el("allergensProductId").value;
                    const product = state.products.find(p => String(p.id) === String(pid));
                    if (product) renderAllergensList(product);
                });

                // toggle przypisania alergenu
                el("allergensList").addEventListener("change", async (ev) => {
                    const chk = ev.target.closest(".allergen-toggle");
                    if (!chk) return;

                    const productId = el("allergensProductId").value;
                    const allergenId = chk.dataset.allergenId;

                    try {
                        chk.disabled = true;

                        let resp;
                        if (chk.checked) resp = await assignAllergen(productId, allergenId);
                        else resp = await unassignAllergen(productId, allergenId);

                        if (resp.success || resp.ok) {
                            const p = state.products.find(x => String(x.id) === String(productId));
                            if (p) {
                                p.allergens = Array.isArray(p.allergens) ? p.allergens : [];

                                const aid = String(allergenId);

                                if (chk.checked) {
                                    // dodaj obiekt alergenu z master listy (żeby tabela mogła od razu pokazać badge)
                                    const found = (window.ALLERGENS || []).find(a => String(a.id) === aid);
                                    if (found && !p.allergens.some(x => String(x.id) === aid)) {
                                        p.allergens.push({ id: found.id, name: found.name, code: found.code });
                                    }
                                } else {
                                    // usuń po id
                                    p.allergens = p.allergens.filter(x => String(x.id) !== aid);
                                }

                                // odśwież UI w modalu (liczniki + układ)
                                renderAllergensList(p);

                                // odśwież tabelę, żeby badge’e się zaktualizowały
                                renderGrid();
                            }
                        } else {
                            chk.checked = !chk.checked;
                            Swal.fire({
                                icon: 'error',
                                title: {{ translations.error|json_encode|raw }},
                                text: resp.message || {{ translations.undefined_error_occurred|json_encode|raw }}
                            });
                        }

                    } catch (err) {
                        console.error(err);
                        chk.checked = !chk.checked;
                        Swal.fire({
                            icon: 'error',
                            title: {{ translations.error|json_encode|raw }},
                            text: {{ translations.no_api_connection|json_encode|raw }}
                        });
                    } finally {
                        chk.disabled = false;
                    }
                });

                // Specification modal: language switching
                document.querySelectorAll('input[name="specLang"]').forEach(radio => {
                    radio.addEventListener('change', (ev) => {
                        const lang = ev.target.value;
                        switchSpecificationLanguage(lang);
                    });
                });

                // Specification modal: save button
                el("btnSaveSpecification").addEventListener("click", saveSpecification);
            }

            async function init() {
                bindEvents();
                await loadProducts();
            }

            init().catch(console.error);
        });
    </script>
    <script src="{{ ROOT }}/assets/js/cropper/cropper.min.js"></script>
{% endblock %}
