<div class="modal fade" id="productModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title mb-0" id="productModalTitle">{{ translations.add_product }}</h5>
                    <div class="small text-muted" id="productModalSubtitle">{{ translations.product_modal_subtitle }}</div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ translations.close }}"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-light-secondary small mb-3">
                    <i class="bi bi-lightning-charge me-1"></i>
                    {{ translations.product_modal_hint }}
                </div>
                <input type="hidden" id="productId" value="">
                <div class="row g-3">

                    <div class="col-8 col-md-6">
                        <label class="form-label">{{ translations.sku }} *</label>
                        <input id="productSku" class="form-control" placeholder="{{ translations.sku_placeholder }}">
                        <div class="form-text">{{ translations.sku_hint }}</div>
                        <div class="invalid-feedback" id="errSku"></div>
                    </div>
                    <div class="col-4">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="productActive" checked>
                            <label class="form-check-label" for="productActive">{{ translations.active }}</label>
                        </div>
                    </div>
                    <div class="col-12">
                        <label class="form-label">{{ translations.name }} *</label>
                        <input id="productName" class="form-control" placeholder="{{ translations.name_placeholder }}">
                        <div class="invalid-feedback" id="errName"></div>
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label">{{ translations.package_quantity }} *</label>
                        <input
                                id="productPackageSize"
                                type="number"
                                step="0.001"
                                min="0"
                                class="form-control"
                                placeholder="{{ translations.package_quantity_placeholder }}"
                        >
                        <div class="form-text">{{ translations.package_quantity_hint }}</div>
                        <div class="invalid-feedback" id="errPackageQty"></div>
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label">{{ translations.package_unit }} *</label>
                        <select id="productPackageUnit" class="form-select">
                            <option value="kg">kg</option>
                            <option value="g">g</option>
                            <option value="ml">ml</option>
                            <option value="l">l</option>
                            <option value="pcs">pcs</option>
                        </select>
                        <div class="form-text">{{ translations.package_unit_hint }}</div>
                        <div class="invalid-feedback" id="errPackageUnit"></div>
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label">{{ translations.vat_rate }}</label>
                        <input type="number" step="0.01" min="0" max="1" class="form-control" id="productVatRate">
                        <div class="invalid-feedback" id="errVatRate"></div>
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label">{{ translations.weight }}</label>
                        <input type="number" step="1" min="0" class="form-control" id="productWeightGrams" placeholder="{{ translations.weight_grams_placeholder }}">
                        <div class="form-text">{{ translations.weight_grams_hint }}</div>
                        <div class="invalid-feedback" id="errWeightGrams"></div>
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label">{{ translations.package_unit }}</label>
                        <select id="productWeightUnit" class="form-select">
                            <option value="g">g</option>
                            <option value="kg">kg</option>
                        </select>
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label">{{ translations.shelf_life_days }}</label>
                        <input type="number" step="1" min="0" class="form-control" id="productShelfLifeDays" placeholder="{{ translations.shelf_life_days_placeholder }}">
                        <div class="form-text">{{ translations.shelf_life_days_hint }}</div>
                        <div class="invalid-feedback" id="errShelfLifeDays"></div>
                    </div>
                </div>
                <div class="mt-3 d-flex justify-content-between align-items-center">
                    <div class="small text-muted" id="modalMeta">{{ translations.modal_meta_new }}</div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-light" data-bs-dismiss="modal">
                            {{ translations.cancel }}
                        </button>
                        <button class="btn btn-primary" id="btnSaveProduct">
                            <i class="bi bi-check-lg me-1"></i>{{ translations.save }}
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
