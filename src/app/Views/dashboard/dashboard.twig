{% extends "layouts/base.twig" %}

{% block title %}{{ translations.supplier_dashboard }}{% endblock %}

{% block page_heading %}
    <div class="page-heading">
        <h3>{{ translations.supplier_dashboard }}</h3>
        <p class="text-subtitle text-muted">{{ translations.supplier_dashboard_subtitle }}</p>
    </div>
{% endblock %}

{% block content %}

    {# alerty globalne (wg Twojego wzorca) #}
    {% include "page_components/alerts.twig" %}

    <div class="row">

        {# QUICK ACTIONS #}
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h4 class="card-title">{{ translations.quick_actions }}</h4>
                </div>
                <div class="card-body">
                    <div class="row g-3">

                        <div class="col-12 col-md-4">
                            <a href="{{ ROOT }}/catalog" class="card border shadow-sm h-100 text-decoration-none">
                                <div class="card-body d-flex gap-3 align-items-start">
                                    <div class="avatar avatar-lg">
                                        <span class="avatar-content bg-light-primary">
                                            <i class="bi bi-box-seam"></i>
                                        </span>
                                    </div>
                                    <div>
                                        <h5 class="mb-1 text-dark">{{ translations.manage_catalog }}</h5>
                                        <div class="text-muted small">{{ translations.manage_catalog_subtitle }}</div>
                                    </div>
                                </div>
                            </a>
                        </div>

                        <div class="col-12 col-md-4">
                            <a href="{{ ROOT }}/clients" class="card border shadow-sm h-100 text-decoration-none">
                                <div class="card-body d-flex gap-3 align-items-start">
                                    <div class="avatar avatar-lg">
                                        <span class="avatar-content bg-light-success">
                                            <i class="bi bi-tags"></i>
                                        </span>
                                    </div>
                                    <div>
                                        <h5 class="mb-1 text-dark">{{ translations.manage_price_lists }}</h5>
                                        <div class="text-muted small">{{ translations.manage_price_lists_subtitle }}</div>
                                    </div>
                                </div>
                            </a>
                        </div>

                        <div class="col-12 col-md-4">
                            <a href="{{ ROOT }}/me" class="card border shadow-sm h-100 text-decoration-none">
                                <div class="card-body d-flex gap-3 align-items-start">
                                    <div class="avatar avatar-lg">
                                        <span class="avatar-content bg-light-warning">
                                            <i class="bi bi-person"></i>
                                        </span>
                                    </div>
                                    <div>
                                        <h5 class="mb-1 text-dark">{{ translations.view_profile }}</h5>
                                        <div class="text-muted small">{{ translations.view_profile_subtitle }}</div>
                                    </div>
                                </div>
                            </a>
                        </div>

                    </div>
                </div>
            </div>
        </div>

        {# STATS #}
        <div class="col-12">
            <div class="row g-3">

                <div class="col-12 col-md-4">
                    <div class="card h-100">
                        <div class="card-body d-flex align-items-center justify-content-between">
                            <div>
                                <div class="text-muted small">{{ translations.products_in_catalog }}</div>
                                <div class="fs-3 fw-bold">{{ stats.catalog_products_count|default(0) }}</div>
                            </div>
                            <i class="bi bi-box-seam fs-2 text-muted"></i>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-md-4">
                    <div class="card h-100">
                        <div class="card-body d-flex align-items-center justify-content-between">
                            <div>
                                <div class="text-muted small">{{ translations.active_price_lists }}</div>
                                <div class="fs-3 fw-bold">{{ stats.price_lists_count|default(0) }}</div>
                            </div>
                            <i class="bi bi-tags fs-2 text-muted"></i>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-md-4">
                    <div class="card h-100">
                        <div class="card-body d-flex align-items-center justify-content-between">
                            <div>
                                <div class="text-muted small">{{ translations.last_update }}</div>
                                <div class="fw-bold">
                                    {{ stats.last_update|default(translations.not_available) }}
                                </div>
                            </div>
                            <i class="bi bi-clock-history fs-2 text-muted"></i>
                        </div>
                    </div>
                </div>

            </div>
        </div>

    </div>
{% endblock %}
