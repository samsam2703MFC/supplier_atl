{% extends "layouts/error_mobile.twig" %}

{% block title %}404{% endblock %}

{% block illustration %}
    <img class="merr-illu" src="{{ ROOT }}/assets/mazer/static/images/samples/error-404.svg" alt="Not found">
{% endblock %}

{% block error_title %}
    {{ translations.not_found ?? 'Not found' }}
{% endblock %}

{% block error_subtitle %}
    {{ translations.not_found_subtitle ?? 'The page you’re looking for doesn’t exist or has been moved.' }}
{% endblock %}

{% block footer %}
    <div class="small text-muted mt-3">Error code: 404</div>
{% endblock %}
