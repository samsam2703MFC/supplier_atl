        els.deliveryCountry.value = transport.delivery_country || order.shop?.country_code || order.shop_country_code || '';
        els.instructions.value = transport.instructions || transport.note || '';
        const selectedCarrierId = transport.carrier_id || transport.carrier?.id || transport.carrier_snapshot?.id || '';
        ensureCarriersLoaded(false).then(() => {
            ensureCarrierOption(selectedCarrierId, transport.carrier_snapshot || transport.carrier || null);
            els.carrier.value = selectedCarrierId ? String(selectedCarrierId) : '';
            updateSupplierDisplay();
            markTransportSnapshotSaved(transportPersisted);
        }).catch((error) => {
            console.warn('Initial carrier load failed', error);
            renderCarrierSelect();
            ensureCarrierOption(selectedCarrierId, transport.carrier_snapshot || transport.carrier || null);
            els.carrier.value = selectedCarrierId ? String(selectedCarrierId) : '';
            updateSupplierDisplay();
            markTransportSnapshotSaved(transportPersisted);
        });
        updateTransportVisibility(false);
        markTransportSnapshotSaved(transportPersisted);
    }

    function updateTransportVisibility(showLoadError = false) {
        const isExternal = els.type.value === 'EXTERNAL';
        if (els.carrierWrap) els.carrierWrap.style.display = isExternal ? '' : 'none';
        if (isExternal && showLoadError) {
            ensureCarriersLoaded(true).catch(() => {
                Swal.fire({ icon:'error', text: tr.network });
            });
        }
        updateSupplierDisplay();
        updateTransportSaveState();
    }

    async function loadCarriers() {
        const resp = await api('/ajax/orders/carriers', { method: 'GET' });
        if (resp?.ok === false) throw new Error(apiMessage(resp, tr.network));
        carriers = normalizeApiList(resp);
        carriersLoaded = true;
        renderCarrierSelect();
        updateSupplierDisplay();
        return carriers;
    }

    async function ensureCarriersLoaded(force = false) {
        if (!force && carriersLoaded) return carriers;
        if (!force && carriersLoading) return carriersLoading;
        carriersLoading = loadCarriers().finally(() => { carriersLoading = null; });
        return carriersLoading;
    }

    function normalizeApiList(resp) {
        if (Array.isArray(resp)) return resp;
        if (Array.isArray(resp?.data)) return resp.data;
        if (Array.isArray(resp?.data?.data)) return resp.data.data;
        if (Array.isArray(resp?.items)) return resp.items;
        return [];
    }

    function selectedCarrier() {
        const selectedId = String(els.carrier?.value || '');
        return carriers.find((carrier) => String(carrier.id) === selectedId) || null;
    }

    function ensureCarrierOption(carrierId, carrier = null) {
        if (!els.carrier || carrierId === null || carrierId === undefined || carrierId === '') return;
        const id = String(carrierId);
        const hasOption = Array.from(els.carrier.options).some((option) => option.value === id);
        if (hasOption) return;
        const option = document.createElement('option');
        option.value = id;
        option.textContent = carrier?.name || carrier?.label || `#${id}`;
        option.dataset.snapshot = '1';
        els.carrier.appendChild(option);
    }

    function updateSupplierDisplay() {
        if (!els.supplierValue) return;
        const carrier = els.type?.value === 'EXTERNAL' ? selectedCarrier() : null;
        els.supplierValue.textContent = carrier?.name || tr.supplierDefaultLabel || '—';
    }

    function carrierIsActive(carrier) {
        return carrier.is_active !== false && carrier.active !== false && carrier.status !== 'INACTIVE';
    }

    function renderCarrierSelect() {
        const current = els.carrier.value;
        const existingSnapshot = Array.from(els.carrier.options).find((option) => option.value === current && option.dataset.snapshot === '1');
        const options = carriers.filter(carrierIsActive).map((carrier) => `<option value="${escapeHtml(carrier.id)}">${escapeHtml(carrier.name || '')}</option>`).join('');
        els.carrier.innerHTML = `<option value="">${escapeHtml({{ translations.orders_carriers_select|json_encode|raw }})}</option>${options}`;
        if (existingSnapshot && !Array.from(els.carrier.options).some((option) => option.value === current)) {
            els.carrier.appendChild(existingSnapshot);
        }
        els.carrier.value = current;
        updateSupplierDisplay();
    }

    function validateTransportPayload(payload, showMessage = true) {
        if (!payload.planned_delivery_date) {
            if (showMessage) Swal.fire({ icon:'error', title: tr.validation, text: tr.plannedDateRequired });
            return false;
        }
        if (payload.mode === 'EXTERNAL' && !payload.carrier_id) {
            if (showMessage) Swal.fire({ icon:'error', title: tr.validation, text: tr.externalCarrierRequired });
            return false;
        }
        return true;
    }

    async function persistTransport(showSuccess = false, showValidation = showSuccess) {
        const payload = transportPayload();
        if (!validateTransportPayload(payload, showValidation)) {
            return { ok: false, validation: true };
        }

        const resp = await api(`/ajax/orders/${orderId}/transport`, { method: 'PUT', data: payload });
        if (resp.ok && showSuccess) {
            await Swal.fire({ icon:'success', title: tr.savedTitle, text: tr.savedText, timer: 1000, showConfirmButton:false });
        }

        return resp;
    }

    async function saveTransport() {
        if (transportBusy) return;
        transportBusy = true;
        els.save.disabled = true;
        try {
            const resp = await persistTransport(true);
            if (resp.ok) {
                markTransportSnapshotSaved(true);
                window.location.reload();
                return;
            }
            if (resp.validation) return;
            if (resp.status === 409) { await showConflict(); return; }
            Swal.fire({ icon:'error', title: tr.validation, text: apiMessage(resp, tr.server) });
        } catch (e) {
            Swal.fire({ icon:'error', text: tr.network });
        } finally {
            transportBusy = false;
            els.save.disabled = false;
        }
    }

    function carrierAddressLine(carrier) {
        return [carrier.address, carrier.postal_code, carrier.city, carrier.country].filter(Boolean).join(' ') || '—';
    }

    async function carrierForm(carrier = null) {
        const result = await Swal.fire({
            icon: 'question',
            title: carrier ? tr.carrierEdit : tr.carrierAdd,
            width: 760,
            html: `
                <div class="row g-2 text-start">
                    <div class="col-12 col-md-6">
                        <label class="form-label">${escapeHtml(tr.carrierName)}</label>
                        <input id="carrier-name" class="form-control" value="${escapeHtml(carrier?.name || '')}">
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label">${escapeHtml(tr.carrierDriverName)}</label>
                        <input id="carrier-driver-name" class="form-control" value="${escapeHtml(carrier?.driver_name || '')}">
                    </div>
                    <div class="col-12">
                        <label class="form-label">${escapeHtml(tr.carrierAddress)}</label>
                        <input id="carrier-address" class="form-control" value="${escapeHtml(carrier?.address || '')}">
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label">${escapeHtml(tr.carrierPostalCode)}</label>
                        <input id="carrier-postal-code" class="form-control" value="${escapeHtml(carrier?.postal_code || '')}">
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label">${escapeHtml(tr.carrierCity)}</label>
                        <input id="carrier-city" class="form-control" value="${escapeHtml(carrier?.city || '')}">
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label">${escapeHtml(tr.carrierCountry)}</label>
                        <input id="carrier-country" class="form-control" maxlength="2" value="${escapeHtml(carrier?.country || '')}">
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label">${escapeHtml(tr.carrierVehicleRegistrationNumber)}</label>
                        <input id="carrier-vehicle-registration-number" class="form-control" value="${escapeHtml(carrier?.vehicle_registration_number || '')}">
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label">${escapeHtml(tr.carrierTaxIdentifier)}</label>
                        <input id="carrier-tax-identifier" class="form-control" value="${escapeHtml(carrier?.tax_identifier || '')}">
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label">${escapeHtml(tr.carrierPhone)}</label>
                        <input id="carrier-phone" class="form-control" value="${escapeHtml(carrier?.phone || '')}">
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label">${escapeHtml(tr.carrierEmail)}</label>
                        <input id="carrier-email" class="form-control" value="${escapeHtml(carrier?.email || '')}">
                    </div>
                </div>
            `,
            showCancelButton: true,
            confirmButtonText: tr.save,
            cancelButtonText: tr.close,
            preConfirm: () => {
                const name = document.getElementById('carrier-name').value.trim();
                if (!name) { Swal.showValidationMessage(tr.carrierNameRequired); return false; }
                const value = (id) => document.getElementById(id)?.value.trim() || '';
                return {
                    name,
                    driver_name: value('carrier-driver-name') || null,
                    address: value('carrier-address') || null,
                    postal_code: value('carrier-postal-code') || null,
                    city: value('carrier-city') || null,
                    country: value('carrier-country') || null,
                    vehicle_registration_number: value('carrier-vehicle-registration-number') || null,
                    tax_identifier: value('carrier-tax-identifier') || null,
                    phone: value('carrier-phone') || null,
                    email: value('carrier-email') || null
                };
            }
        });
        if (!result.value) return;
        const endpoint = carrier ? `/ajax/orders/carriers/${carrier.id}` : '/ajax/orders/carriers';
        const method = carrier ? 'PATCH' : 'POST';
        const resp = await api(endpoint, { method, data: result.value });
        if (!resp.ok) { Swal.fire({ icon:'error', text: apiMessage(resp, tr.server) }); return; }
        await Swal.fire({ icon:'success', title: carrier ? tr.carrierSavedTitle : tr.carrierCreatedTitle, text: carrier ? tr.carrierSavedText : tr.carrierCreatedText, timer: 1000, showConfirmButton:false });
        await loadCarriers();
        window.location.reload();
    }

    async function deactivateCarrier(carrier) {
        const confirmed = await Swal.fire({ icon:'warning', text: tr.carrierConfirmDeactivate, showCancelButton:true, confirmButtonText: tr.carrierDeactivate, cancelButtonText: tr.close });
        if (!confirmed.isConfirmed) return;
        const resp = await api(`/ajax/orders/carriers/${carrier.id}`, { method:'DELETE' });
        if (!resp.ok) { Swal.fire({ icon:'error', text: apiMessage(resp, tr.server) }); return; }
        await loadCarriers();
        window.location.reload();
    }

    async function showCarrierManager() {
        const rows = carriers.length ? carriers.map((carrier) => `
            <tr>
                <td class="text-center">
                    <button type="button" class="btn btn-sm btn-outline-danger carrier-deactivate" data-id="${carrier.id}" title="${escapeHtml(tr.carrierDeactivate)}" aria-label="${escapeHtml(tr.carrierDeactivate)}" ${carrierIsActive(carrier) ? '' : 'disabled'}><i class="dripicons-trash"></i></button>
                </td>
                <td>${escapeHtml(carrier.name || '')}</td>
                <td>${escapeHtml(carrier.driver_name || '—')}</td>
                <td>${escapeHtml(carrierAddressLine(carrier))}</td>
                <td>${escapeHtml(carrier.vehicle_registration_number || '—')}</td>
                <td>${carrierIsActive(carrier) ? 'ACTIVE' : 'INACTIVE'}</td>
                <td class="text-end">
                    <button type="button" class="btn btn-sm btn-outline-primary carrier-edit" data-id="${carrier.id}">${escapeHtml(tr.carrierEdit)}</button>
                </td>
            </tr>
        `).join('') : `<tr><td colspan="7" class="text-muted">${escapeHtml(tr.carriersEmpty)}</td></tr>`;
        await Swal.fire({
            title: tr.carriersTitle,
            width: 800,
            html: `<div class="text-end mb-2"><button type="button" id="carrier-add" class="btn btn-sm btn-primary">${escapeHtml(tr.carrierAdd)}</button></div><div class="table-responsive"><table class="table table-sm align-middle"><thead><tr><th class="text-center">${escapeHtml(tr.carrierDeactivate)}</th><th>${escapeHtml(tr.carrierName)}</th><th>${escapeHtml(tr.carrierDriverName)}</th><th>${escapeHtml(tr.carrierAddress)}</th><th>${escapeHtml(tr.carrierVehicleRegistrationNumber)}</th><th>${escapeHtml(tr.carrierStatus)}</th><th class="text-end">${escapeHtml(tr.carrierActions)}</th></tr></thead><tbody>${rows}</tbody></table></div>`,
            showConfirmButton: false,
            showCloseButton: true,
            didOpen: () => {
                document.getElementById('carrier-add')?.addEventListener('click', () => carrierForm());
                document.querySelectorAll('.carrier-edit').forEach((btn) => btn.addEventListener('click', () => carrierForm(carriers.find((carrier) => String(carrier.id) === btn.dataset.id))));
                document.querySelectorAll('.carrier-deactivate').forEach((btn) => btn.addEventListener('click', () => deactivateCarrier(carriers.find((carrier) => String(carrier.id) === btn.dataset.id))));
            }
        });
    }

    function finalizationIssueText(item) {
        if (typeof item === 'string') return tr.finalizationErrorMessages[item] || item;
        if (!item || typeof item !== 'object') return String(item ?? '');
        const code = item.code || item.error || item.message_code;
        return item.message || item.description || (code ? (tr.finalizationErrorMessages[code] || code) : JSON.stringify(item));
    }

    function listHtml(items, empty) {
        if (!Array.isArray(items) || !items.length) return `<p class="text-muted">${escapeHtml(empty)}</p>`;
        return `<ul class="finalization-list">${items.map((item) => `<li>${escapeHtml(finalizationIssueText(item))}</li>`).join('')}</ul>`;
    }

    async function showConflict() {
        const result = await Swal.fire({ icon:'warning', title: tr.conflictTitle, text: tr.conflictText, showCancelButton:true, confirmButtonText: tr.refresh, cancelButtonText: tr.close });
        if (result.isConfirmed) window.location.reload();
    }

    async function finalizeOrder() {
        if (finalizeBusy) return;
        finalizeBusy = true;
        els.finalizeStart.disabled = true;
        try {
            const transportData = transportPayload();
            if (!validateTransportPayload(transportData, true)) {
                return;
            }
            if (transportNeedsSave()) {
                updateTransportSaveState();
                await Swal.fire({ icon:'warning', title: tr.transportUnsavedTitle, text: tr.transportUnsavedText, confirmButtonText: tr.save });
                els.save?.focus();
                return;
            }
            Swal.fire({ title: tr.finalizeChecking, allowOutsideClick:false, didOpen: () => Swal.showLoading() });
            const check = await api(`/ajax/orders/${orderId}/finalization-check`, { method:'POST', data:{ version: Number(version) } });
            Swal.close();
            if (check.status === 409) { await showConflict(); return; }
            if (!check.ok) { Swal.fire({ icon:'error', text: apiMessage(check, tr.server) }); return; }
            const errors = check.errors || check.data?.errors || [];
            const warnings = check.warnings || check.data?.warnings || [];
            const comparison = check.comparison || check.data?.comparison || [];
            const transport = check.transport || check.data?.transport || transportPayload();
            const comparisonRows = Array.isArray(comparison?.items) ? comparison.items : (Array.isArray(comparison) ? comparison : []);
            const comparisonHtml = comparisonRows.length ? `<ul class="finalization-list">${comparisonRows.map((row) => `<li>${escapeHtml(row.material_name || row.name || row.label || '')}: ${escapeHtml(row.ordered_pack_quantity ?? '—')} → ${escapeHtml(row.final_pack_quantity ?? '—')}</li>`).join('')}</ul>` : `<p class="text-muted">${escapeHtml({{ translations.orders_details_no_comparison|json_encode|raw }})}</p>`;
            const html = `
                <h6>${escapeHtml(tr.finalizeErrors)}</h6>${listHtml(errors, tr.finalizeNoIssues)}
                <h6 class="mt-3">${escapeHtml(tr.finalizeWarnings)}</h6>${listHtml(warnings, tr.finalizeNoIssues)}
                <h6 class="mt-3">${escapeHtml(tr.finalizeComparison)}</h6>${comparisonHtml}
                <h6 class="mt-3">${escapeHtml(tr.finalizeTransport)}</h6>
                <p class="text-muted mb-0">${escapeHtml(transport.mode || 'OWN')} · ${escapeHtml(transport.planned_delivery_date || transport.planned_date || '')}</p>
            `;
            const result = await Swal.fire({ icon: errors.length ? 'error' : 'question', title: tr.finalizeTitle, html, showCancelButton: !errors.length, showConfirmButton: !errors.length, confirmButtonText: tr.finalizeConfirm, cancelButtonText: tr.close, width: 760 });
            if (!result.isConfirmed) return;
            const finalized = await api(`/ajax/orders/${orderId}/finalize`, { method:'POST', data:{ version: Number(version) } });
            if (finalized.status === 409) { await showConflict(); return; }
            if (!finalized.ok) { Swal.fire({ icon:'error', text: apiMessage(finalized, tr.server) }); return; }
            await Swal.fire({ icon:'success', title: tr.finalizedTitle, text: tr.finalizedText, timer: 1200, showConfirmButton:false });
            window.location.reload();
        } catch (e) {
            Swal.fire({ icon:'error', text: tr.network });
        } finally {
            finalizeBusy = false;
            els.finalizeStart.disabled = false;
        }
    }

    if (editable) {
        els.type?.addEventListener('change', () => { updateTransportVisibility(true); updateTransportSaveState(); });
        els.carrier?.addEventListener('change', () => { updateSupplierDisplay(); updateTransportSaveState(); });
        [els.plannedDate, els.loadingPlace, els.loadingCountry, els.deliveryPlace, els.deliveryCountry, els.instructions].forEach((input) => {
            input?.addEventListener('input', updateTransportSaveState);
            input?.addEventListener('change', updateTransportSaveState);
        });
        els.carrier?.addEventListener('focus', () => ensureCarriersLoaded(true).catch(() => Swal.fire({ icon:'error', text: tr.network })));
        els.carrier?.addEventListener('click', () => ensureCarriersLoaded(true).catch(() => Swal.fire({ icon:'error', text: tr.network })));
        els.save?.addEventListener('click', saveTransport);
    }
    els.carriersManage?.addEventListener('click', async () => { try { await ensureCarriersLoaded(true); await showCarrierManager(); } catch (e) { Swal.fire({ icon:'error', text: tr.network }); } });
    els.finalizeStart?.addEventListener('click', finalizeOrder);
    populateTransport();
})();


(() => {
    const panel = document.getElementById('cmr-status-panel');
    if (!panel) return;

    const orderId = panel.dataset.orderId;
    const badge = document.getElementById('cmr-status-badge');
    const statusText = document.getElementById('cmr-status-text');
    const missingList = document.getElementById('cmr-missing-list');
    const generateButton = document.getElementById('cmr-generate');
    const downloadButton = document.getElementById('cmr-download');
    let busy = false;
    let currentDocument = null;

    const t = {
        loading: {{ translations.orders_cmr_loading|json_encode|raw }},
        notApplicable: {{ translations.orders_cmr_not_applicable|json_encode|raw }},
        missingData: {{ translations.orders_cmr_missing_data|json_encode|raw }},
        eligible: {{ translations.orders_cmr_eligible|json_encode|raw }},
        generated: {{ translations.orders_cmr_generated|json_encode|raw }},
        invalidated: {{ translations.orders_cmr_invalidated|json_encode|raw }},
        unknown: {{ translations.orders_cmr_unknown|json_encode|raw }},
        statusError: {{ translations.orders_cmr_status_error|json_encode|raw }},
        generateTitle: {{ translations.orders_cmr_generate_title|json_encode|raw }},
        generateText: {{ translations.orders_cmr_generate_text|json_encode|raw }},
        generateConfirm: {{ translations.orders_cmr_generate_confirm|json_encode|raw }},
        generateError: {{ translations.orders_cmr_generate_error|json_encode|raw }},
        conflictTitle: {{ translations.orders_lifecycle_conflict_title|json_encode|raw }},
        conflictText: {{ translations.orders_documents_conflict_text|json_encode|raw }},
        refresh: {{ translations.orders_final_editor_refresh|json_encode|raw }},
        close: {{ translations.orders_action_close|json_encode|raw }},
        downloadError: {{ translations.orders_documents_download_error|json_encode|raw }},
        missingPrefix: {{ translations.orders_cmr_missing_prefix|json_encode|raw }},
        localPrefix: {{ translations.orders_cmr_local_missing_prefix|default('Wymagania do wygenerowania CMR:')|json_encode|raw }},
        localStatusErrorPrefix: {{ translations.orders_cmr_local_status_error_prefix|default('Nie udało się pobrać statusu CMR. Lokalnie widoczne wymagania:')|json_encode|raw }},
        localNoMissing: {{ translations.orders_cmr_local_no_missing|default('Nie wykryto braków w danych widocznych w panelu. Sprawdź odpowiedź API dla statusu CMR.')|json_encode|raw }},
        errorMap: {
            ORDER_CMR_DOCUMENT_NOT_APPLICABLE: {{ translations.orders_document_error_ORDER_CMR_DOCUMENT_NOT_APPLICABLE|json_encode|raw }},
            ORDER_CMR_DOCUMENT_MISSING_DATA: {{ translations.orders_document_error_ORDER_CMR_DOCUMENT_MISSING_DATA|json_encode|raw }},
            ORDER_CMR_DOCUMENT_REQUIRES_FINALIZED: {{ translations.orders_document_error_ORDER_CMR_DOCUMENT_REQUIRES_FINALIZED|json_encode|raw }},
            ORDER_CMR_DOCUMENT_TRANSPORT_REQUIRED: {{ translations.orders_document_error_ORDER_CMR_DOCUMENT_TRANSPORT_REQUIRED|json_encode|raw }},
            ORDER_CMR_DOCUMENT_WEIGHT_REQUIRED: {{ translations.orders_document_error_ORDER_CMR_DOCUMENT_WEIGHT_REQUIRED|json_encode|raw }},
            ORDER_NOT_FINALIZED: {{ translations.orders_cmr_requirement_order_finalized|default('Zamówienie musi być sfinalizowane.')|json_encode|raw }},
            ORDER_TRANSPORT_REQUIRED: {{ translations.orders_cmr_requirement_transport_required|default('Uzupełnij dane transportu.')|json_encode|raw }},
            ORDER_TRANSPORT_TYPE_ROAD_REQUIRED: {{ translations.orders_cmr_requirement_transport_type_road|default('Typ transportu musi być drogowy (ROAD).')|json_encode|raw }},
            ORDER_TRANSPORT_LOADING_PLACE_REQUIRED: {{ translations.orders_cmr_requirement_loading_place|default('Uzupełnij miejsce załadunku.')|json_encode|raw }},
            ORDER_TRANSPORT_LOADING_COUNTRY_REQUIRED: {{ translations.orders_cmr_requirement_loading_country|default('Uzupełnij kraj załadunku.')|json_encode|raw }},
            ORDER_TRANSPORT_DELIVERY_PLACE_REQUIRED: {{ translations.orders_cmr_requirement_delivery_place|default('Uzupełnij miejsce dostawy.')|json_encode|raw }},
            ORDER_TRANSPORT_DELIVERY_COUNTRY_REQUIRED: {{ translations.orders_cmr_requirement_delivery_country|default('Uzupełnij kraj dostawy.')|json_encode|raw }},
            ORDER_TRANSPORT_PLANNED_DELIVERY_DATE_REQUIRED: {{ translations.orders_cmr_requirement_planned_delivery_date|default('Uzupełnij planowaną datę dostawy.')|json_encode|raw }},
            CMR_FINAL_ITEMS_REQUIRED: {{ translations.orders_cmr_requirement_final_items|default('Finalne pozycje muszą zawierać co najmniej jedną pozycję z ilością większą od zera.')|json_encode|raw }},
            ORDER_DOCUMENT_NOT_FOUND: {{ translations.orders_document_error_ORDER_DOCUMENT_NOT_FOUND|json_encode|raw }},
            ORDER_DOCUMENT_NOT_ACTIVE: {{ translations.orders_document_error_ORDER_DOCUMENT_NOT_ACTIVE|json_encode|raw }},
            IDEMPOTENCY_KEY_CONFLICT: {{ translations.orders_document_error_IDEMPOTENCY_KEY_CONFLICT|json_encode|raw }}
        }
    };

    function escapeHtml(value) {
        return String(value ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#039;');
    }

    function parseJson(value, fallback) {
        try {
            return JSON.parse(value || '');
        } catch (error) {
            return fallback;
        }
    }

    function normalizeList(value) {
        if (!value) return [];
        if (Array.isArray(value)) return value;
        if (typeof value === 'object') return Object.values(value).flat();
        return [value];
    }

    function labelRequirement(item) {
        if (item?.label) return String(item.label);
        const code = String(item?.code || item?.field || item?.message || item || '');
        return t.errorMap[code] || code;
    }

    function showMissing(items, prefix) {
        const list = normalizeList(items).filter(Boolean);
        if (!list.length) {
            missingList.classList.add('d-none');
            missingList.innerHTML = '';
            return;
        }
        missingList.classList.remove('d-none');
        missingList.innerHTML = list.map((item) => `<li>${escapeHtml(labelRequirement(item))}</li>`).join('');
        statusText.textContent = prefix;
    }

    function localRequirements() {
        const missing = [];
        const orderStatus = String(panel.dataset.orderStatus || '').toUpperCase();
        const transport = parseJson(panel.dataset.transport, {});
        const finalItems = parseJson(panel.dataset.finalItems, []);

        if (orderStatus !== 'FINALIZED') missing.push('ORDER_NOT_FINALIZED');
        if (!transport || !Object.keys(transport).length) {
            missing.push('ORDER_TRANSPORT_REQUIRED');
        } else {
            if (String(transport.transport_type || '').toUpperCase() !== 'ROAD') missing.push('ORDER_TRANSPORT_TYPE_ROAD_REQUIRED');
            ['loading_place', 'loading_country', 'delivery_place', 'delivery_country', 'planned_delivery_date'].forEach((field) => {
                if (transport[field] === null || transport[field] === undefined || String(transport[field]).trim() === '') {
                    missing.push(`ORDER_TRANSPORT_${field.toUpperCase()}_REQUIRED`);
                }
            });
        }

        const hasPositiveFinalItem = finalItems.some((item) => Number(item.final_pack_quantity ?? item.pack_quantity ?? item.quantity ?? 0) > 0);
        if (!hasPositiveFinalItem) missing.push('CMR_FINAL_ITEMS_REQUIRED');

        return missing;
    }

    function renderLocalDiagnostic(statusClass = 'bg-warning text-dark', prefix = t.localPrefix) {
        const missing = localRequirements();
        badge.className = `badge ${missing.length ? statusClass : 'bg-secondary'}`;
        badge.textContent = missing.length ? t.missingData : t.unknown;
        if (missing.length) {
            showMissing(missing, prefix);
        } else {
            missingList.classList.add('d-none');
            missingList.innerHTML = '';
            statusText.textContent = t.localNoMissing;
        }
        generateButton.classList.toggle('d-none', panel.dataset.canGenerate !== '1');
        generateButton.disabled = busy;
    }

    function hasGenerateAction(actions) {
        const list = normalizeList(actions).map((action) => String(action?.code || action?.name || action).toLowerCase());
        return list.some((action) => ['generate_cmr_document', 'generate_cmr'].includes(action));
    }

    function documentFrom(data) {
        return data?.document || data?.active_document || data?.cmr_document || data?.latest_document || null;
    }

    function statusFrom(data, document) {
        const raw = data?.qualification_status || data?.cmr_status || data?.status || data?.state || data?.result || '';
        const docStatus = document?.status || '';
        if (String(docStatus).toUpperCase() === 'INVALIDATED') return 'INVALIDATED';
        if (!raw && String(docStatus).toUpperCase() === 'GENERATED') return 'GENERATED';
        return String(raw || docStatus || 'UNKNOWN').toUpperCase();
    }

    function statusLabel(status) {
        return ({
            ELIGIBLE: t.eligible,
            NOT_APPLICABLE: t.notApplicable,
            MISSING_DATA: t.missingData,
            GENERATED: t.generated,
            INVALIDATED: t.invalidated
        })[status] || t.unknown;
    }

    function badgeClass(status) {
        return ({
            ELIGIBLE: 'bg-success',
            NOT_APPLICABLE: 'bg-secondary',
            MISSING_DATA: 'bg-warning text-dark',
            GENERATED: 'bg-success',
            INVALIDATED: 'bg-secondary'
        })[status] || 'bg-secondary';
    }

    function apiMessage(resp, fallback) {
        const code = resp?.code || resp?.error_code || resp?.description || resp?.message;
        if (typeof code === 'string' && t.errorMap[code]) return t.errorMap[code];
        if (resp?.errors && typeof resp.errors === 'object') return Object.values(resp.errors).flat().join('\n') || fallback;
        if (Array.isArray(resp?.message)) return resp.message.join('\n');
        return resp?.description || resp?.message || fallback;
    }

    function render(data) {
        currentDocument = documentFrom(data);
        const status = statusFrom(data, currentDocument);
        const missing = normalizeList(data?.missing_data || data?.missing || data?.missing_fields || data?.requirements_missing);
        const canGenerate = panel.dataset.canGenerate === '1' || hasGenerateAction(data?.allowed_actions || data?.actions);
        const documentId = currentDocument?.id || data?.document_id || null;
        const activeDocument = documentId && !['INVALIDATED', 'VOIDED', 'CANCELLED'].includes(String(currentDocument?.status || '').toUpperCase());

        badge.className = `badge ${badgeClass(status)}`;
        badge.textContent = statusLabel(status);
        statusText.textContent = statusLabel(status);

        if (missing.length) {
            showMissing(missing, t.missingPrefix);
        } else {
            missingList.classList.add('d-none');
            missingList.innerHTML = '';
        }

        generateButton.classList.toggle('d-none', !canGenerate);
        generateButton.disabled = busy;
        downloadButton.classList.toggle('d-none', !activeDocument);
        downloadButton.dataset.documentId = activeDocument ? documentId : '';
        downloadButton.dataset.documentNumber = currentDocument?.number || currentDocument?.document_number || documentId || '';
    }

    async function loadStatus() {
        statusText.textContent = t.loading;
        try {
            const resp = await api(`/ajax/orders/${orderId}/documents/cmr/status`);
            if (!resp.ok) {
                renderLocalDiagnostic('bg-danger', t.localStatusErrorPrefix);
                const message = apiMessage(resp, t.statusError);
                if (message && message !== t.statusError) {
                    statusText.textContent = `${t.localStatusErrorPrefix} ${message}`;
                }
                return;
            }
            render(resp.data || resp);
        } catch (error) {
            renderLocalDiagnostic('bg-danger', t.localStatusErrorPrefix);
        }
    }

    generateButton.addEventListener('click', async () => {
        if (busy) return;
        const confirmed = await Swal.fire({
            icon: 'question',
            title: t.generateTitle,
            text: t.generateText,
            showCancelButton: true,
            confirmButtonText: t.generateConfirm,
            cancelButtonText: t.close
        });
        if (!confirmed.isConfirmed) return;

        busy = true;
        generateButton.disabled = true;
        try {
            const resp = await api(`/ajax/orders/${orderId}/documents/cmr`, { method: 'POST', data: {} });
            if (resp.ok) {
                await Swal.fire({ icon: 'success', title: {{ translations.orders_documents_generate_success_title|json_encode|raw }}, text: {{ translations.orders_documents_generate_success_text|json_encode|raw }}, timer: 1200, showConfirmButton: false });
                window.location.reload();
                return;
            }
            if (resp.status === 409) {
                const result = await Swal.fire({ icon: 'warning', title: t.conflictTitle, text: t.conflictText, showCancelButton: true, confirmButtonText: t.refresh, cancelButtonText: t.close });
                if (result.isConfirmed) window.location.reload();
                return;
            }
            Swal.fire({ icon: 'error', text: apiMessage(resp, t.generateError) });
            await loadStatus();
        } catch (error) {
            Swal.fire({ icon: 'error', text: t.generateError });
        } finally {
            busy = false;
            generateButton.disabled = false;
        }
    });

    downloadButton.addEventListener('click', async () => {
        if (!downloadButton.dataset.documentId) return;
        downloadButton.disabled = true;
        try {
            await downloadPdf(
                `/orders/${orderId}/documents/${downloadButton.dataset.documentId}/download`,
                {},
                `order-${orderId}-cmr-${downloadButton.dataset.documentNumber || downloadButton.dataset.documentId}.pdf`,
                'GET'
            );
        } catch (error) {
            Swal.fire({ icon: 'error', text: error.message || t.downloadError });
        } finally {
            downloadButton.disabled = false;
        }
    });

    loadStatus();
})();

(() => {
    const panel = document.getElementById('order-documents-panel');
    if (!panel) return;

    const orderId = panel.dataset.orderId;
    const generateButtons = Array.from(panel.querySelectorAll('.js-document-generate'));
    let generateBusy = false;

    const td = {
        downloadError: {{ translations.orders_documents_download_error|json_encode|raw }},
        generateSuccessTitle: {{ translations.orders_documents_generate_success_title|json_encode|raw }},
        generateSuccessText: {{ translations.orders_documents_generate_success_text|json_encode|raw }},
        generateError: {{ translations.orders_documents_generate_error|json_encode|raw }},
        generateReleaseError: {{ translations.orders_documents_generate_release_error|json_encode|raw }},
        releaseErrorMap: {
            ORDER_RELEASE_DOCUMENT_REQUIRES_FINALIZED: {{ translations.orders_document_error_ORDER_RELEASE_DOCUMENT_REQUIRES_FINALIZED|json_encode|raw }},
            ORDER_RELEASE_DOCUMENT_FINAL_ITEMS_REQUIRED: {{ translations.orders_document_error_ORDER_RELEASE_DOCUMENT_FINAL_ITEMS_REQUIRED|json_encode|raw }},
            ORDER_RELEASE_DOCUMENT_TRANSPORT_REQUIRED: {{ translations.orders_document_error_ORDER_RELEASE_DOCUMENT_TRANSPORT_REQUIRED|json_encode|raw }},
            ORDER_DOCUMENT_NOT_FOUND: {{ translations.orders_document_error_ORDER_DOCUMENT_NOT_FOUND|json_encode|raw }},
            ORDER_DOCUMENT_NOT_ACTIVE: {{ translations.orders_document_error_ORDER_DOCUMENT_NOT_ACTIVE|json_encode|raw }},
            IDEMPOTENCY_KEY_CONFLICT: {{ translations.orders_document_error_IDEMPOTENCY_KEY_CONFLICT|json_encode|raw }}
        },
        conflictTitle: {{ translations.orders_lifecycle_conflict_title|json_encode|raw }},
        conflictText: {{ translations.orders_documents_conflict_text|json_encode|raw }},
        refresh: {{ translations.orders_final_editor_refresh|json_encode|raw }},
        close: {{ translations.orders_action_close|json_encode|raw }}
    };

    function apiMessage(resp, fallback) {
        const code = resp?.code || resp?.error_code || resp?.description || resp?.message;
        if (typeof code === 'string' && td.releaseErrorMap[code]) return td.releaseErrorMap[code];
        if (resp?.errors && typeof resp.errors === 'object') return Object.values(resp.errors).flat().join('\n') || fallback;
        if (Array.isArray(resp?.message)) return resp.message.join('\n');
        return resp?.description || resp?.message || fallback;
    }

    panel.querySelectorAll('.js-document-download').forEach((button) => {
        button.addEventListener('click', async () => {
            button.disabled = true;
            try {
                await downloadPdf(
                    `/orders/${orderId}/documents/${button.dataset.documentId}/download`,
                    {},
                    `order-${orderId}-${button.dataset.documentNumber || button.dataset.documentId}.pdf`,
                    'GET'
                );
            } catch (error) {
                Swal.fire({ icon: 'error', text: error.message || td.downloadError });
            } finally {
                button.disabled = false;
            }
        });
    });

    generateButtons.forEach((generateButton) => {
        generateButton.addEventListener('click', async () => {
            if (generateBusy) return;
            const kind = generateButton.dataset.documentKind || 'difference';
            const fallbackError = kind === 'release' ? td.generateReleaseError : td.generateError;
            generateBusy = true;
            generateButtons.forEach((button) => { button.disabled = true; });
            try {
                const resp = await api(`/ajax/orders/${orderId}/documents/${kind}`, { method: 'POST', data: {} });
                if (resp.ok) {
                    await Swal.fire({ icon: 'success', title: td.generateSuccessTitle, text: td.generateSuccessText, timer: 1200, showConfirmButton: false });
                    window.location.reload();
                    return;
                }
                if (resp.status === 409) {
                    const result = await Swal.fire({ icon: 'warning', title: td.conflictTitle, text: td.conflictText, showCancelButton: true, confirmButtonText: td.refresh, cancelButtonText: td.close });
                    if (result.isConfirmed) window.location.reload();
                    return;
                }
                Swal.fire({ icon: 'error', text: apiMessage(resp, fallbackError) });
            } catch (error) {
                Swal.fire({ icon: 'error', text: fallbackError });
            } finally {
                generateBusy = false;
                generateButtons.forEach((button) => { button.disabled = false; });
            }
        });
    });
})();

</script>
{% endblock %}
