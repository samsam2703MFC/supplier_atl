    function hasPersistedTransport(transport) {
        return Boolean(transport && typeof transport === 'object' && (
            transport.id || transport.material_order_id || transport.mode || transport.planned_delivery_date ||
            transport.loading_place || transport.delivery_place || transport.carrier_id
        ));
    }

    function transportNeedsSave() {
