{% set p = current_path|default('') %}

<div id="sidebar" class="active">
    <div class="sidebar-wrapper active ds-side">

        <div class="ds-side__brand">
            <a href="{{ ROOT }}/dashboard" class="ds-side__logo-link">
                <img src="{{ ROOT }}/assets/images/atelierby.png" alt="L'Atelier by">
            </a>
            <div class="ds-side__portal t-admin-label">{{ translations.supplier_portal|default('Portail Fournisseur') }}</div>
        </div>

        <nav class="ds-side__nav">

            {# ── Pilotage / Zarządzanie ──────────────────────────────────── #}
            <div class="ds-side__group-title t-admin-label">{{ translations.menu_group_management|default('Zarządzanie') }}</div>
            <ul class="ds-side__list">
                <li class="sidebar-item {{ p starts with '/dashboard' ? 'active' : '' }}">
                    <a href="{{ ROOT }}/dashboard" class="sidebar-link ds-side__link">
                        <i class="bi bi-grid-1x2-fill"></i>
                        <span>{{ translations.supplier_dashboard }}</span>
                    </a>
                </li>
                <li class="sidebar-item {{ p == '/analytics' ? 'active' : '' }}">
                    <a href="{{ ROOT }}/analytics" class="sidebar-link ds-side__link">
                        <i class="bi bi-bar-chart-line"></i>
                        <span>{{ translations.analytics }}</span>
                    </a>
                </li>
                <li class="sidebar-item {{ p starts with '/analytics/raw-material-sales-all-shops' ? 'active' : '' }}">
                    <a href="{{ ROOT }}/analytics/raw-material-sales-all-shops" class="sidebar-link ds-side__link">
                        <i class="bi bi-shop-window"></i>
                        <span>{{ translations.rms_all_menu ?? 'All Shops Sales' }}</span>
                    </a>
                </li>
            </ul>

            {# ── Offre / Oferta ──────────────────────────────────────────── #}
            <div class="ds-side__group-title t-admin-label">{{ translations.menu_group_offer|default('Oferta') }}</div>
            <ul class="ds-side__list">
                <li class="sidebar-item {{ p starts with '/catalog' ? 'active' : '' }}">
                    <a href="{{ ROOT }}/catalog" class="sidebar-link ds-side__link">
                        <i class="bi bi-box-seam"></i>
                        <span>{{ translations.catalog }}</span>
                    </a>
                </li>
                <li class="sidebar-item {{ p starts with '/raw-materials' ? 'active' : '' }}">
                    <a href="{{ ROOT }}/raw-materials" class="sidebar-link ds-side__link">
                        <i class="bi bi-egg-fried"></i>
                        <span>{{ translations.raw_materials }}</span>
                    </a>
                </li>
                <li class="sidebar-item {{ p starts with '/recipes' ? 'active' : '' }}">
                    <a href="{{ ROOT }}/recipes" class="sidebar-link ds-side__link">
                        <i class="bi bi-journal-text"></i>
                        <span>{{ translations.recipes }}</span>
                    </a>
                </li>
                <li class="sidebar-item {{ p starts with '/price-list' ? 'active' : '' }}">
                    <a href="{{ ROOT }}/price-list" class="sidebar-link ds-side__link">
                        <i class="bi bi-tag"></i>
                        <span>{{ translations.global_price_list_menu|default('Cennik') }}</span>
                    </a>
                </li>
            </ul>

            {# ── Activité / Działalność ──────────────────────────────────── #}
            <div class="ds-side__group-title t-admin-label">{{ translations.menu_group_activity|default('Działalność') }}</div>
            <ul class="ds-side__list">
                <li class="sidebar-item {{ p starts with '/orders' ? 'active' : '' }}">
                    <a href="{{ ROOT }}/orders" class="sidebar-link ds-side__link">
                        <i class="bi bi-receipt"></i>
                        <span>{{ translations.orders }}</span>
                    </a>
                </li>
                <li class="sidebar-item {{ p starts with '/logistics' ? 'active' : '' }}">
                    <a href="{{ ROOT }}/logistics" class="sidebar-link ds-side__link">
                        <i class="bi bi-truck"></i>
                        <span>{{ translations.logistics }}</span>
                    </a>
                </li>
                <li class="sidebar-item {{ p starts with '/complaints' ? 'active' : '' }}">
                    <a href="{{ ROOT }}/complaints" class="sidebar-link ds-side__link">
                        <i class="bi bi-exclamation-triangle"></i>
                        <span>{{ translations.complaints }}</span>
                        {% if open_complaints_count is defined and open_complaints_count > 0 %}
                            <span class="ds-side__badge">{{ open_complaints_count }}</span>
                        {% endif %}
                    </a>
                </li>
                <li class="sidebar-item {{ p starts with '/clients' ? 'active' : '' }}">
                    <a href="{{ ROOT }}/clients" class="sidebar-link ds-side__link">
                        <i class="bi bi-people"></i>
                        <span>{{ translations.client }}</span>
                    </a>
                </li>
            </ul>

            {# ── Compte / Konto ──────────────────────────────────────────── #}
            <div class="ds-side__group-title t-admin-label">{{ translations.menu_group_account|default('Konto') }}</div>
            <ul class="ds-side__list">
                <li class="sidebar-item {{ p starts with '/me' ? 'active' : '' }}">
                    <a href="{{ ROOT }}/me" class="sidebar-link ds-side__link">
                        <i class="bi bi-person"></i>
                        <span>{{ translations.my_profile }}</span>
                    </a>
                </li>
            </ul>

        </nav>

        <div class="ds-side__footer">
            <div class="ds-side__avatar">{{ (user.displayName|default('FS'))|slice(0, 2)|upper }}</div>
            <div class="ds-side__user">
                <div class="ds-side__user-name">{{ user.displayName|default(translations.supplier|default('Fournisseur')) }}</div>
                <div class="ds-side__user-role t-admin-label">{{ user.role|default(translations.supplier|default('Fournisseur')) }}</div>
            </div>
            <a href="{{ ROOT }}/logout" class="ds-side__logout" title="{{ translations.logout }}">
                <i class="bi bi-box-arrow-right"></i>
            </a>
        </div>

        <button class="sidebar-toggler btn x"><i data-feather="x"></i></button>
    </div>
</div>
