                        <div class="col-12 mt-2">
                            <h6 class="text-muted text-uppercase small mb-1">{{ translations.section_extra }}</h6>
                        </div>

                        <div class="col-12">
                            <label class="form-label">{{ translations.description }}</label>
                            <textarea class="form-control" id="qrmDescription" rows="2" maxlength="5000"></textarea>
                            <div class="invalid-feedback" id="qrmErrDescription"></div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer d-flex justify-content-between">
                    <small class="text-muted">{{ translations.modal_meta_new }}</small>
                    <div>
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">{{ translations.cancel }}</button>
                        <button type="button" class="btn btn-primary" id="btnConfirmQuickAddRm">
                            <i class="bi bi-floppy2-fill me-1"></i>{{ translations.save }}
                        </button>
