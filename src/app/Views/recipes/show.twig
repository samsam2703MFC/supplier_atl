        ['vidCartonType', 'vidDepositPerCarton'].forEach(id => el(id).classList.remove('is-invalid'));

        const typeRaw    = el('vidCartonType').value.trim();
        const depositRaw = el('vidDepositPerCarton').value.trim();

        const data = {
            vidanges_carton_type:        typeRaw    === '' ? null : typeRaw,
            vidanges_deposit_per_carton: depositRaw === '' ? null : parseDecimalOrNull(depositRaw),
        };

        const resp = await api('/ajax/recipes/' + RECIPE_ID, { method: 'PATCH', data });

        if (!resp.ok) {
            const errors = resp.data?.errors ?? {};
            const map = {
                vidanges_carton_type:        ['vidCartonType',       'errVidCartonType'],
                vidanges_deposit_per_carton: ['vidDepositPerCarton', 'errVidDeposit'],
            };
            let handled = false;
            Object.keys(map).forEach(k => {
                if (errors[k]) {
                    const [inputId, errId] = map[k];
                    el(inputId).classList.add('is-invalid');
                    el(errId).textContent = errors[k];
                    handled = true;
                }
            });
            if (!handled) {
                Swal.fire('{{ translations.error }}', resp.data?.description ?? '{{ translations.undefined_error_occurred }}', 'error');
            }
            return;
        }

        recomputeVidanges();
        Swal.fire({ icon: 'success', title: '{{ translations.success }}', text: '{{ translations.operation_successful }}', timer: 1200, showConfirmButton: false });
    });

    // -----------------------------------------------------------------------
    //  Tile 9 — P&L summary (live calc + save target_margin)
    // -----------------------------------------------------------------------
    function recomputePnl() {
        const ppp          = parseIntOrNull(el('suPortionsPerPack').value);
        const ppc          = parseIntOrNull(el('suPacksPerCarton').value);
        const laborTime    = parseDecimalOrNull(el('laborTime').value);
        const laborRate    = parseDecimalOrNull(el('laborRate').value);
        const ohForecast   = parseIntOrNull(el('ohForecast').value);
        const ohPool       = parseDecimalOrNull(el('ohPool').value);
        const marginPct    = parseFloat(el('pnlMarginSlider').value) || 0;
        const rawMaterialPricing = getRawMaterialPricingFromInputs();

        el('pnlMarginOut').textContent     = marginPct.toFixed(2) + '%';
        el('pnlMarginContext').textContent = '({{ translations.pnl_margin }} ' + marginPct.toFixed(2) + '%)';

        // portionsPerCarton is needed for overhead
        const portionsPerCarton = (ppp !== null && ppc !== null) ? ppp * ppc : null;

        // raw materials
        const rawMatPack = rawMaterialPricing.perPackaging;
        const rawMatCarton = rawMaterialPricing.perCarton;
        const rawMatPortion = rawMaterialPricing.perPortion;

        // labor
        const laborPerUnit = (laborTime !== null && laborRate !== null)
            ? (laborTime / 60.0) * laborRate : null;
        const laborPack = (laborPerUnit !== null && ppp !== null)
            ? laborPerUnit * ppp : null;
        const laborCarton = (laborPack !== null && ppc !== null && ppc > 0)
            ? laborPack * ppc : null;
        const laborPortion = (laborCarton !== null && portionsPerCarton !== null && portionsPerCarton > 0)
            ? laborCarton / portionsPerCarton : null;

        // overhead
        let ohPack = null;
        if (ohForecast !== null && ohForecast > 0 && ohPool !== null && portionsPerCarton !== null && portionsPerCarton > 0 && ppp !== null) {
            const ohPerPortion = ohPool / ohForecast / portionsPerCarton;
            ohPack = ohPerPortion * ppp;
        }
        const ohCarton = (ohPack !== null && ppc !== null && ppc > 0) ? ohPack * ppc : null;
        const ohPortion = (ohCarton !== null && portionsPerCarton !== null && portionsPerCarton > 0)
            ? ohCarton / portionsPerCarton : null;

        const packagingCost = parseDecimalOrNull(el('packCost').value);
        const packagingCarton = (packagingCost !== null && ppc !== null && ppc > 0) ? packagingCost * ppc : null;
        const packagingPortion = (packagingCarton !== null && portionsPerCarton !== null && portionsPerCarton > 0)
            ? packagingCarton / portionsPerCarton : null;

        // cost totals
        const allCosts = rawMatPack !== null && laborPack !== null && ohPack !== null;
        const totalPack = allCosts ? rawMatPack + laborPack + ohPack + (packagingCost ?? 0) : null;
        const totalCarton = (totalPack !== null && ppc !== null && ppc > 0) ? totalPack * ppc : null;
        const totalPortion = (totalCarton !== null && portionsPerCarton !== null && portionsPerCarton > 0)
            ? totalCarton / portionsPerCarton : null;

        // update cost table — per carton
        const fmt = v => v !== null ? v.toFixed(2) + ' ' + CURRENCY : '—';
        el('pnlRowMat').textContent      = fmt(rawMatCarton);
        el('pnlRowLabor').textContent    = fmt(laborCarton);
        el('pnlRowOverhead').textContent = fmt(ohCarton);
        el('pnlRowPackaging').textContent = packagingCarton !== null ? fmt(packagingCarton) : '{{ translations.pnl_packaging_not_set }}';
        el('pnlRowTotal').textContent   = fmt(totalCarton);

        // recommended price
        let recPrice = null;
        if (totalCarton !== null) {
            const mf = marginPct / 100.0;
            recPrice = mf >= 0.9899 ? totalCarton * 100.0 : totalCarton / (1.0 - mf);
        }
        const perPortionPrice = (recPrice !== null && portionsPerCarton !== null && portionsPerCarton > 0)
            ? recPrice / portionsPerCarton : null;

        el('pnlRecommendedPrice').textContent = fmt(recPrice);
        el('pnlPerPortionPrice').textContent  = fmt(perPortionPrice);

        // vidanges
        const depPerCart = parseDecimalOrNull(el('vidDepositPerCarton').value);
        const vidCarton = depPerCart;
        const vidPortion = (depPerCart !== null && portionsPerCarton !== null && portionsPerCarton > 0)
            ? depPerCart / portionsPerCarton : null;
        el('pnlVidVal').textContent = fmt(vidCarton);

        // update cost table — per portion
        const portFmt = v => v !== null ? v.toFixed(2) + ' ' + CURRENCY : '—';
        el('pnlPortRowMat').textContent       = portFmt(rawMatPortion);
        el('pnlPortRowLabor').textContent     = portFmt(laborPortion);
        el('pnlPortRowOverhead').textContent  = portFmt(ohPortion);
        el('pnlPortRowPackaging').textContent = packagingPortion !== null ? portFmt(packagingPortion) : '{{ translations.pnl_packaging_not_set }}';
        el('pnlPortRowTotal').textContent     = portFmt(totalPortion);
        el('pnlPortRecommendedPrice').textContent = fmt(perPortionPrice);
        el('pnlPortVidVal').textContent = portFmt(vidPortion);

        // context info
        if (portionsPerCarton !== null) {
            el('pnlSuInfo').querySelector('strong').textContent = portionsPerCarton + ' {{ translations.pnl_portions }}';
        }

        updatePnlIncompleteAlert(rawMatCarton, portionsPerCarton, laborTime, laborRate, ohForecast, ohPool);
    }

    // Hook Tile 9 slider to live compute
    el('pnlMarginSlider').addEventListener('input', recomputePnl);

    // P&L view toggle: per carton ↔ per portion
    el('btnPnlViewCarton').addEventListener('click', () => {
        el('pnlCartonView').classList.remove('d-none');
        el('pnlPortionView').classList.add('d-none');
        el('btnPnlViewCarton').classList.replace('btn-outline-primary', 'btn-primary');
        el('btnPnlViewPortion').classList.replace('btn-primary', 'btn-outline-primary');
    });
    el('btnPnlViewPortion').addEventListener('click', () => {
        el('pnlPortionView').classList.remove('d-none');
        el('pnlCartonView').classList.add('d-none');
        el('btnPnlViewPortion').classList.replace('btn-outline-primary', 'btn-primary');
        el('btnPnlViewCarton').classList.replace('btn-primary', 'btn-outline-primary');
    });

    // Also recompute when upstream tiles change
    ['suPortionSize', 'suPortionUnit', 'suPortionsPerPack', 'suPacksPerCarton', 'laborTime', 'laborRate', 'ohForecast', 'ohPool', 'vidDepositPerCarton', 'packCost'].forEach(id => {
        const node = el(id);
