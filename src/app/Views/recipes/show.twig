                            <input type="text" class="form-control" id="qrmSku" maxlength="100">
                            <div class="invalid-feedback" id="qrmErrSku"></div>
                        </div>
                        <div class="col-md-8">
                            <label class="form-label">{{ translations.name }} <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="qrmName" maxlength="255">
                            <div class="invalid-feedback" id="qrmErrName"></div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">{{ translations.category }}</label>
                            <div class="input-group">
                                <select class="form-select" id="qrmCategory">
                                    <option value="">{{ translations.no_category }}</option>
                                </select>
                                <button type="button" class="btn btn-outline-secondary" id="btnQrmManageCategories" title="{{ translations.manage_categories }}">
                                    <i class="bi bi-gear"></i>
                                </button>
                            </div>
                            <div class="invalid-feedback" id="qrmErrCategory"></div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">{{ translations.unit }} <span class="text-danger">*</span></label>
                            <select class="form-select" id="qrmUnit">
                                <option value="">{{ translations.loading }}</option>
                            </select>
                            <div class="invalid-feedback" id="qrmErrUnit"></div>
                        </div>

                        <div class="col-12 mt-2">
                            <h6 class="text-muted text-uppercase small mb-1">{{ translations.section_pricing }}</h6>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">{{ translations.vat_rate }}</label>
                            <input type="number" step="0.01" min="0" max="100" class="form-control" id="qrmVatRate">
                            <div class="invalid-feedback" id="qrmErrVatRate"></div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">{{ translations.waste_perc }}</label>
                            <input type="number" step="0.01" min="0" max="100" class="form-control" id="qrmWastePerc">
