                el('qrmBtnCancelCatEdit').style.display = 'none';
            } catch (e) {
                el('qrmErrCategoryName').textContent = e.message || '{{ translations.undefined_error_occurred }}';
            }
        });

        el('qrmBtnCancelCatEdit').addEventListener('click', () => {
            el('qrmCatEditId').value = '';
            el('qrmCatNameInput').value = '';
            el('qrmErrCategoryName').textContent = '';
            el('qrmBtnCancelCatEdit').style.display = 'none';
        });

        el('qrmCategoryList').addEventListener('click', async (ev) => {
