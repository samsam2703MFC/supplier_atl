    async function handleProductSelect() {
        const sel       = el('calcProductId');
        const productId = sel.value ? parseInt(sel.value, 10) : null;

        // ── Case A: user cleared the product → unlink and reload ──
        if (!productId) {
            const resp = await api('/ajax/recipes/' + RECIPE_ID, {
                method: 'PATCH',
                data: { product_id: null },
            });
            if (!resp.ok) {
                Swal.fire('{{ translations.error }}', resp.data?.description ?? '{{ translations.undefined_error_occurred }}', 'error');
                return;
            }
            window.location.reload();
            return;
        }

        // ── Case B: product selected — search for an existing recipe for this product ──
        const searchResp = await api('/ajax/recipes', {
            method: 'GET',
            data: { product_id: productId },
        });

        if (!searchResp.ok) {
            Swal.fire('{{ translations.error }}', '{{ translations.undefined_error_occurred }}', 'error');
            return;
        }

        const existing = Array.isArray(searchResp.data) ? searchResp.data : [];

        // ── Case B1: recipe for this product already exists → navigate to it ──
        if (existing.length > 0) {
            const found = existing[0];
            if (found.id !== RECIPE_ID) {
                window.location.href = '{{ ROOT }}/recipes/' + found.id;
            }
            // already on the correct recipe page — nothing to do
            return;
        }

        // ── Case B2: no recipe for this product yet → ask user to create one ──
        const product     = productMap.get(String(productId));
        const productName = product?.name ?? '';

        const confirm = await Swal.fire({
            title: '{{ translations.no_recipe_for_product_title }}',
            html:  '{{ translations.no_recipe_for_product_body }}'.replace('{name}', '<strong>' + escapeHtml(productName) + '</strong>'),
            icon:  'question',
            showCancelButton:   true,
            confirmButtonText:  '{{ translations.create_recipe }}',
            cancelButtonText:   '{{ translations.cancel }}',
        });

        if (!confirm.isConfirmed) {
            // Reset select back to the currently saved product
            el('calcProductId').value = {{ recipe.product_id is not null ? recipe.product_id : 'null' }};
            updateProductPreview();
            return;
        }

        // Create a new recipe for this product
        const createResp = await api('/ajax/recipes', {
            method: 'POST',
            data: { name: productName || '{{ translations.new_recipe }}', product_id: productId },
        });

        if (!createResp.ok) {
            Swal.fire('{{ translations.error }}', createResp.data?.description ?? '{{ translations.undefined_error_occurred }}', 'error');
            return;
        }

        const newId = createResp.inserted_id;
        if (!newId) {
            Swal.fire('{{ translations.error }}', '{{ translations.undefined_error_occurred }}', 'error');
            return;
        }

        window.location.href = '{{ ROOT }}/recipes/' + newId;
    }

