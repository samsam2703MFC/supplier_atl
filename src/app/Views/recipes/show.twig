    {# ===== MODAL: Labor defaults ===== #}
    <div class="modal fade" id="modalLaborDefaults" tabindex="-1" aria-labelledby="modalLaborDefaultsLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="modalLaborDefaultsLabel">
                        <i class="bi bi-gear me-2"></i>{{ translations.labor_defaults_modal_title }}
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ translations.close }}"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted small">{{ translations.labor_defaults_hint }}</p>
