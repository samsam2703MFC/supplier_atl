            } else {
                Swal.fire('{{ translations.error }}', resp.data?.description ?? '{{ translations.undefined_error_occurred }}', 'error');
            }
            return;
        }

        recomputePnl();
        Swal.fire({ icon: 'success', title: '{{ translations.success }}', text: '{{ translations.operation_successful }}', timer: 1200, showConfirmButton: false });
    });

    // -----------------------------------------------------------------------
    //  Tile 2 — Full raw material modal + category management
    // -----------------------------------------------------------------------
    (function () {
        const modalEl    = document.getElementById('modalQuickAddRm');
        const bsModal    = new bootstrap.Modal(modalEl);
        const catModalEl = document.getElementById('qrmCategoryModal');
        const bsCatModal = new bootstrap.Modal(catModalEl);

        let unitsLoaded      = false;
        let qrmCategories    = [];

        // ---- helpers ----
        function calcPricePerUnit(price, qty) {
            if (!price || !qty || Number(price) <= 0 || Number(qty) <= 0) return null;
            return Number(price) / Number(qty);
        }

        function updateInitPriceCalc() {
            const price  = el('qrmInitPackagePrice').value;
            const qty    = el('qrmInitPackageQty').value;
            const sel    = el('qrmUnit');
            let unitLbl  = '—';
            if (sel && sel.value) {
                const opt = sel.options[sel.selectedIndex];
                unitLbl = (opt.textContent || '').split(' — ')[0].trim() || '—';
            }
            el('qrmInitPackageUnit').textContent  = unitLbl;
            el('qrmInitPerUnitSuffix').textContent = unitLbl;
            const result = calcPricePerUnit(price, qty);
            el('qrmInitPricePerUnit').value = result != null ? result.toFixed(2) : '';
        }

        function rebuildCategorySelect(keepVal) {
            const sel = el('qrmCategory');
            const cur = keepVal !== undefined ? keepVal : sel.value;
            sel.innerHTML = '<option value="">{{ translations.no_category }}</option>' +
                qrmCategories.map(c => `<option value="${escapeHtml(String(c.id))}">${escapeHtml(c.name)}</option>`).join('');
            sel.value = String(cur);
        }

        function clearErrors() {
            ['qrmSku','qrmName','qrmCategory','qrmUnit','qrmVatRate','qrmWastePerc','qrmDescription'].forEach(id => {
                const el2 = el(id);
                if (el2) el2.classList.remove('is-invalid');
            });
            ['qrmErrSku','qrmErrName','qrmErrCategory','qrmErrUnit','qrmErrVatRate','qrmErrWastePerc','qrmErrDescription'].forEach(id => {
                const el2 = el(id);
                if (el2) el2.textContent = '';
            });
        }

        function applyErrors(errors) {
            const map = {
                sku: ['qrmSku','qrmErrSku'], name: ['qrmName','qrmErrName'],
                id_category: ['qrmCategory','qrmErrCategory'], id_unit: ['qrmUnit','qrmErrUnit'],
                vat_rate: ['qrmVatRate','qrmErrVatRate'], waste_perc: ['qrmWastePerc','qrmErrWastePerc'],
                description: ['qrmDescription','qrmErrDescription'],
            };
            Object.entries(errors || {}).forEach(([k, msg]) => {
                const pair = map[k];
                if (!pair) return;
                const inp = el(pair[0]), errEl = el(pair[1]);
                if (inp) inp.classList.add('is-invalid');
                if (errEl) errEl.textContent = msg;
            });
        }

        async function loadLookups() {
            const [unitsResp, catsResp] = await Promise.all([
                unitsLoaded ? Promise.resolve(null) : api('/ajax/raw-material-units', { method: 'GET' }),
                api('/ajax/raw-material-categories', { method: 'GET' }),
            ]);

            if (unitsResp && (unitsResp.ok || unitsResp.success) && Array.isArray(unitsResp.data)) {
                const sel = el('qrmUnit');
                sel.innerHTML = '<option value="">—</option>';
                unitsResp.data.forEach(u => {
                    const opt = document.createElement('option');
                    opt.value = u.id;
                    opt.textContent = (u.symbol || u.code || '') + (u.name ? ' — ' + u.name : '');
                    sel.appendChild(opt);
                });
                unitsLoaded = true;
            }

            if ((catsResp.ok || catsResp.success) && Array.isArray(catsResp.data)) {
                qrmCategories = catsResp.data;
                rebuildCategorySelect('');
            }
        }

        // ---- open modal ----
        el('btnOpenQuickAddRm').addEventListener('click', async () => {
            clearErrors();
            ['qrmSku','qrmName','qrmVatRate','qrmWastePerc','qrmDescription'].forEach(id => { el(id).value = ''; });
            el('qrmCategory').value = '';
            el('qrmUnit').value = '';
            el('qrmInitPackagePrice').value = '';
            el('qrmInitPackageQty').value = '1';
            el('qrmInitPricePerUnit').value = '';
            el('qrmInitPackageUnit').textContent = '—';
            el('qrmInitPerUnitSuffix').textContent = '—';
            bsModal.show();
            await loadLookups();
        });

        el('qrmUnit').addEventListener('change', updateInitPriceCalc);
        el('qrmInitPackagePrice').addEventListener('input', updateInitPriceCalc);
        el('qrmInitPackageQty').addEventListener('input', updateInitPriceCalc);

        // ---- save ----
        el('btnConfirmQuickAddRm').addEventListener('click', async () => {
            clearErrors();

            const name   = el('qrmName').value.trim();
            const unitId = el('qrmUnit').value || null;

            let hasClientError = false;
            if (!name) {
                el('qrmName').classList.add('is-invalid');
                el('qrmErrName').textContent = '{{ translations.field_required }}';
                hasClientError = true;
            }
            if (!unitId) {
                el('qrmUnit').classList.add('is-invalid');
                el('qrmErrUnit').textContent = '{{ translations.field_required }}';
                hasClientError = true;
            }
            if (hasClientError) return;

            const numOrNull = v => (v === '' || v == null) ? null : Number(v);
            const strOrNull = v => (v === '' || v == null) ? null : String(v).trim();

            const data = {
                name,
                id_unit:     parseInt(unitId, 10),
                sku:         strOrNull(el('qrmSku').value),
                id_category: el('qrmCategory').value ? Number(el('qrmCategory').value) : null,
                vat_rate:    numOrNull(el('qrmVatRate').value),
                waste_perc:  numOrNull(el('qrmWastePerc').value),
                description: strOrNull(el('qrmDescription').value),
            };

            el('btnConfirmQuickAddRm').disabled = true;
            try {
                const resp = await api('/ajax/raw-materials', { method: 'POST', data });

                if (!(resp.ok || resp.success)) {
                    if (resp.data?.errors || resp.errors) {
                        applyErrors(resp.data?.errors ?? resp.errors);
                        Swal.fire({ icon: 'error', title: '{{ translations.error }}', text: '{{ translations.fix_form_errors }}' });
                    } else {
                        Swal.fire('{{ translations.error }}', resp.data?.description ?? resp.description ?? '{{ translations.undefined_error_occurred }}', 'error');
                    }
                    return;
                }

                // Optional initial price
                const pkgPrice = el('qrmInitPackagePrice').value;
                const pkgQty   = el('qrmInitPackageQty').value;
                const priceNet = calcPricePerUnit(pkgPrice, pkgQty);
                const newId    = resp.inserted_id ?? resp.data?.id;
                if (priceNet && newId) {
                    try {
                        await api(`/ajax/raw-materials/${newId}/price-history`, {
                            method: 'POST',
                            data: { price_net: parseFloat(priceNet.toFixed(4)), valid_from: new Date().toISOString().split('T')[0] }
                        });
                    } catch (e) { console.warn('Initial price save failed', e); }
                }

                // Inject new option into ingredient select
                if (newId) {
                    const unitOpt = el('qrmUnit').options[el('qrmUnit').selectedIndex];
                    const unitSymbol = unitOpt ? unitOpt.textContent.split(' — ')[0].trim() : '';
                    const opt = document.createElement('option');
                    opt.value = newId;
                    opt.dataset.unit = unitSymbol;
                    opt.textContent = escapeHtml(name) + (unitSymbol ? ' (' + unitSymbol + ')' : '');
                    el('newRawMaterialId').appendChild(opt);
                    el('newRawMaterialId').value = String(newId);
                    el('newQtyUnit').textContent = unitSymbol || '—';
                }

                bsModal.hide();
                Swal.fire({ icon: 'success', title: '{{ translations.success }}', text: '{{ translations.raw_material_added }}', timer: 1500, showConfirmButton: false });
            } finally {
                el('btnConfirmQuickAddRm').disabled = false;
            }
        });

        // ---- category management sub-modal ----
        function renderQrmCategoryList() {
            const tEdit   = {{ translations.edit_category|json_encode|raw }};
