                showCancelButton: true,
                confirmButtonText: '{{ translations.delete }}',
                cancelButtonText:  '{{ translations.cancel }}',
                confirmButtonColor: '#EF4444',
            });
            if (!confirmed.isConfirmed) return;

            const resp = await api('/ajax/recipes/' + RECIPE_ID, { method: 'DELETE' });
            if (!resp.ok) {
                const desc = resp.data?.description ?? '';
                const msg = desc === 'RECIPE_HAS_INGREDIENTS'
                    ? '{{ translations.error_has_ingredients }}'
                    : (desc || '{{ translations.undefined_error_occurred }}');
                Swal.fire('{{ translations.error }}', msg, 'error');
                return;
            }
            window.location.href = '{{ ROOT }}/recipes';
        });
    }
});
</script>
{% endblock %}
