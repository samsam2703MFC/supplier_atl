                                        <div class="input-group input-group-sm">
                                            <input type="text" class="form-control bg-light fw-semibold" id="qrmInitPricePerUnit" readonly placeholder="—">
                                            <span class="input-group-text" id="qrmInitPerUnitSuffix">—</span>
