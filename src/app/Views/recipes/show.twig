    });

    // Initial run — sync alert with current input state on page load
    recomputeRawMaterialPricing();
    recomputePnl();

    el('btnSavePnl').addEventListener('click', async () => {
        el('errPnlMargin').textContent = '';
        el('pnlMarginSlider').classList.remove('is-invalid');

        const marginVal = parseFloat(el('pnlMarginSlider').value);

        const resp = await api('/ajax/recipes/' + RECIPE_ID, {
            method: 'PATCH',
