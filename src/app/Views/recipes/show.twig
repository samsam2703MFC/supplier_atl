                        <label class="form-label">{{ translations.labor_time_per_unit }}</label>
                        <div class="input-group">
                            <input type="number" step="0.1" min="0" max="9999.99" class="form-control"
                                   id="ldTime"
                                   value="{{ laborDefaults is defined and laborDefaults.labor_time_default is not null ? laborDefaults.labor_time_default : '' }}">
                            <span class="input-group-text">{{ translations.labor_unit_min }}</span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">{{ translations.labor_hourly_rate }}</label>
                        <div class="input-group">
                            <input type="number" step="0.01" min="0" max="9999999.99" class="form-control"
                                   id="ldRate"
                                   value="{{ laborDefaults is defined and laborDefaults.labor_rate_default is not null ? laborDefaults.labor_rate_default : '' }}">
                            <span class="input-group-text">{{ currency }}/h</span>
                        </div>
