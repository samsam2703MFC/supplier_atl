                            <i class="bi bi-pencil text-primary"></i>
                        </button>
                        <button type="button" class="btn btn-sm btn-link p-0 text-danger qrm-cat-delete" data-id="${escapeHtml(String(c.id))}" title="${escapeHtml(tDelete)}">
                            <i class="bi bi-trash3"></i>
                        </button>
                    </span>
                </li>`).join('');
        }

        el('btnQrmManageCategories').addEventListener('click', () => {
            el('qrmCatEditId').value = '';
            el('qrmCatNameInput').value = '';
            el('qrmErrCategoryName').textContent = '';
            el('qrmBtnCancelCatEdit').style.display = 'none';
            renderQrmCategoryList();
