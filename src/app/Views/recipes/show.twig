    {# ===== MODAL: Manage raw material categories (from quick-add) ===== #}
    <div class="modal fade" id="qrmCategoryModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-tags me-2"></i>{{ translations.manage_categories }}
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ translations.close }}"></button>
                </div>
                <div class="modal-body">
                    <ul class="list-group mb-3" id="qrmCategoryList" style="max-height:260px;overflow-y:auto;"></ul>
                    <div class="input-group">
                        <input type="hidden" id="qrmCatEditId">
