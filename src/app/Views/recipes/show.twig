    function parseDecimalOrNull(v) {
        if (v === null || v === undefined) return null;
        const s = String(v).trim().replace(',', '.');
        if (s === '') return null;
        const n = parseFloat(s);
        return Number.isFinite(n) ? n : null;
    }

    function recomputeLaborCost() {
        const time = parseDecimalOrNull(el('laborTime').value);
        const rate = parseDecimalOrNull(el('laborRate').value);
        const out  = el('laborCostOut');

        if (time === null || rate === null || time < 0 || rate < 0) {
            out.innerHTML = '<span class="text-muted">—</span>';
            return;
        }
        const cost = (time / 60) * rate;
        out.textContent = cost.toFixed(2) + ' ' + CURRENCY;
    }

    el('laborTime').addEventListener('input', recomputeLaborCost);
    el('laborRate').addEventListener('input', recomputeLaborCost);

