    // -----------------------------------------------------------------------
    //  Tile 5 — Overhead (live calc + save + recalculate)
    // -----------------------------------------------------------------------
    function recomputeOverhead() {
        const forecast = parseIntOrNull(el('ohForecast').value);
        const pool     = parseDecimalOrNull(el('ohPool').value);
        const ppp      = parseIntOrNull(el('suPortionsPerPack').value);
        const ppc      = parseIntOrNull(el('suPacksPerCarton').value);
        const portionsPerCarton = (ppp !== null && ppc !== null && ppp >= 1 && ppc >= 1) ? ppp * ppc : null;

        const out = el('ohPerPortionOut');
        if (forecast !== null && forecast > 0 && pool !== null && pool >= 0
            && portionsPerCarton !== null && portionsPerCarton > 0) {
            const perPortion = pool / forecast / portionsPerCarton;
            out.textContent = perPortion.toFixed(2) + ' ' + CURRENCY;
        } else {
            out.innerHTML = '<span class="text-muted">—</span>';
        }

        // Update info line "Based on N portions / carton"
        const info = el('ohSourceInfo');
        if (portionsPerCarton !== null) {
            info.textContent = '{{ translations.overhead_based_on|replace({"{n}": "@@N@@"}) }}'.replace('@@N@@', portionsPerCarton);
            info.classList.remove('text-warning');
        } else {
            info.innerHTML = '<span class="text-warning">{{ translations.overhead_missing_sales_unit }}</span>';
        }
    }

    el('ohForecast').addEventListener('input', recomputeOverhead);
    el('ohPool').addEventListener('input', recomputeOverhead);
    // Re-trigger overhead recalculation when sales unit inputs change
    el('suPortionsPerPack').addEventListener('input', recomputeOverhead);
    el('suPacksPerCarton').addEventListener('input', recomputeOverhead);

