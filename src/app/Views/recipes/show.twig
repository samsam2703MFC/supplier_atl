    function parseIntOrNull(v) {
        if (v === null || v === undefined) return null;
        const s = String(v).trim();
        if (s === '') return null;
        const n = parseInt(s, 10);
        return Number.isFinite(n) ? n : null;
    }

    function recomputeSalesUnit() {
        const portionSize = parseDecimalOrNull(el('suPortionSize').value);
        const portionUnit = el('suPortionUnit').value;
        const ppp         = parseIntOrNull(el('suPortionsPerPack').value);
        const ppc         = parseIntOrNull(el('suPacksPerCarton').value);

        const portionsPerCartonOut = el('suPortionsPerCartonOut');
        const packWeightOut        = el('suPackWeightOut');
        const cartonWeightOut      = el('suCartonWeightOut');

        // portions per carton
        if (ppp !== null && ppc !== null && ppp >= 1 && ppc >= 1) {
            portionsPerCartonOut.textContent = (ppp * ppc).toString();
        } else {
            portionsPerCartonOut.innerHTML = '<span class="text-muted">—</span>';
        }

        // packaging size (in unit)
        let packagingSize = null;
        if (portionSize !== null && portionSize > 0 && ppp !== null && ppp >= 1) {
            packagingSize = portionSize * ppp;
            const noDecUnits = ['g', 'ml', 'szt'];
            const packFmt = noDecUnits.includes(portionUnit) ? Math.round(packagingSize).toString() : packagingSize.toFixed(2);
            packWeightOut.textContent = packFmt + ' ' + portionUnit;
        } else {
            packWeightOut.innerHTML = '<span class="text-muted">—</span>';
        }

        // carton size / weight
        if (packagingSize !== null && ppc !== null && ppc >= 1) {
            const cartonSize = packagingSize * ppc;
            if (portionUnit === 'g') {
                cartonWeightOut.textContent = (cartonSize / 1000).toFixed(2) + ' kg';
            } else if (portionUnit === 'kg') {
                cartonWeightOut.textContent = cartonSize.toFixed(2) + ' kg';
            } else if (portionUnit === 'ml') {
                cartonWeightOut.textContent = Math.round(cartonSize).toString() + ' ' + portionUnit;
            } else if (portionUnit === 'szt') {
                cartonWeightOut.textContent = Math.round(cartonSize).toString() + ' ' + portionUnit;
            } else {
                cartonWeightOut.textContent = cartonSize.toFixed(2) + ' ' + portionUnit;
            }
        } else {
            cartonWeightOut.innerHTML = '<span class="text-muted">—</span>';
        }

        // Yield validation: carton total must not exceed total ingredient quantity
        const yieldWarning     = el('suYieldWarning');
        const yieldWarningText = el('suYieldWarningText');
        if (portionSize !== null && portionSize > 0 && ppp !== null && ppp >= 1 && ppc !== null && ppc >= 1) {
            const cartonTotal = portionSize * ppp * ppc;
            let ingrTotal = null;
            let cartonInBaseUnit = cartonTotal;
            let displayUnit = portionUnit;
            if (portionUnit === 'g') {
                ingrTotal = INGR_TOTAL_G;
            } else if (portionUnit === 'kg') {
                cartonInBaseUnit = cartonTotal * 1000;
                ingrTotal = INGR_TOTAL_G;
                displayUnit = 'g';
            } else if (portionUnit === 'ml') {
                ingrTotal = INGR_TOTAL_ML;
            } else if (portionUnit === 'l') {
                cartonInBaseUnit = cartonTotal * 1000;
                ingrTotal = INGR_TOTAL_ML;
                displayUnit = 'ml';
            } else if (portionUnit === 'szt') {
                ingrTotal = INGR_TOTAL_SZT;
            }
            if (ingrTotal !== null && ingrTotal > 0 && cartonInBaseUnit > ingrTotal) {
                const cartonFmt = Number.isInteger(cartonInBaseUnit) ? cartonInBaseUnit : cartonInBaseUnit.toFixed(2);
                const ingrFmt   = Number.isInteger(ingrTotal)        ? ingrTotal        : ingrTotal.toFixed(2);
                yieldWarningText.textContent = T_YIELD_EXCEEDS
                    .replace('{carton}', cartonFmt + ' ' + displayUnit)
                    .replace('{total}',  ingrFmt   + ' ' + displayUnit);
                yieldWarning.classList.remove('d-none');
            } else {
                yieldWarning.classList.add('d-none');
            }
        } else {
            yieldWarning.classList.add('d-none');
        }
    }

