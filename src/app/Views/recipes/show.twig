</div>{# /.calc-page-wrap #}
{% endblock %}

{% block scripts %}
<script>
document.addEventListener('DOMContentLoaded', function () {
    const RECIPE_ID      = {{ recipe.id|json_encode|raw }};
    const LABOR_DEFAULTS = {{ laborDefaults is defined ? laborDefaults|json_encode|raw : '{}' }};
    const CURRENCY  = {{ currency|json_encode|raw }};
    const PRODUCTS  = {{ products|json_encode|raw }};
    const IS_ARCHIVED = {{ recipe.is_archived ? 'true' : 'false' }};
    // Raw materials pricing derived from the total recipe cost with waste.
    const RAW_MAT_PRICE_PER_KG = {{ recipe.raw_material_pricing.price_per_kg is not null ? recipe.raw_material_pricing.price_per_kg|json_encode|raw : 'null' }};
    const IS_WEIGHT_RECIPE = {{ recipe.raw_material_pricing.is_weight_recipe ? 'true' : 'false' }};
    // Packaging cost per packaging unit (from DB — updated after save)
    const PACK_COST_PER_PACK_INIT = {{ recipe.packaging.cost_per_packaging is not null ? recipe.packaging.cost_per_packaging|json_encode|raw : 'null' }};
    // PnL incomplete warning — translation strings for dynamic alert
    const T_MISSING_PORTIONS = {{ translations.recipe_missing_sales_unit|json_encode|raw }};
    const T_MISSING_RAW_MAT  = {{ translations.recipe_missing_raw_materials|json_encode|raw }};
    const T_MISSING_LABOR    = {{ translations.recipe_missing_labor|json_encode|raw }};
    const T_MISSING_OVERHEAD = {{ translations.recipe_missing_overhead|json_encode|raw }};
    {% set _jsIngrG = 0 %}{% set _jsIngrMl = 0 %}{% set _jsIngrSzt = 0 %}
    {% for _si in ingredients %}
        {% if _si.unit_symbol_snapshot == 'g' %}{% set _jsIngrG = _jsIngrG + _si.quantity %}
        {% elseif _si.unit_symbol_snapshot == 'kg' %}{% set _jsIngrG = _jsIngrG + (_si.quantity * 1000) %}
        {% elseif _si.unit_symbol_snapshot == 'ml' %}{% set _jsIngrMl = _jsIngrMl + _si.quantity %}
        {% elseif _si.unit_symbol_snapshot == 'l' %}{% set _jsIngrMl = _jsIngrMl + (_si.quantity * 1000) %}
        {% elseif _si.unit_symbol_snapshot == 'szt' %}{% set _jsIngrSzt = _jsIngrSzt + _si.quantity %}
        {% endif %}
    {% endfor %}
    const INGR_TOTAL_G   = {{ _jsIngrG }};
    const INGR_TOTAL_ML  = {{ _jsIngrMl }};
    const INGR_TOTAL_SZT = {{ _jsIngrSzt }};
    const T_YIELD_EXCEEDS = {{ translations.sales_unit_carton_exceeds_ingredients|json_encode|raw }};

    const productMap = new Map((PRODUCTS || []).map(p => [String(p.id), p]));

    function el(id) { return document.getElementById(id); }

    function escapeHtml(s) {
        return String(s ?? '').replace(/[&<>"']/g, m => ({
            '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'
        }[m]));
    }

    function updatePnlIncompleteAlert(rawMatPack, ppp, laborTime, laborRate, ohForecast, ohPool) {
        const alertEl = el('pnlIncompleteAlert');
        const listEl  = el('pnlIncompleteList');
        if (!alertEl || !listEl) return;

        const missing = [];
        if (ppp === null || ppp <= 0)                                     missing.push({ key: 'portions',     text: T_MISSING_PORTIONS });
        if (rawMatPack === null)                                           missing.push({ key: 'raw_materials', text: T_MISSING_RAW_MAT });
        if (laborTime === null || laborRate === null)                      missing.push({ key: 'labor',         text: T_MISSING_LABOR });
        if (ohForecast === null || ohForecast <= 0 || ohPool === null)     missing.push({ key: 'overhead',      text: T_MISSING_OVERHEAD });

        if (missing.length === 0) {
            alertEl.style.display = 'none';
            return;
        }
        alertEl.style.display = '';
        listEl.innerHTML = missing.map(m =>
            `<li data-key="${escapeHtml(m.key)}">${escapeHtml(m.text)}</li>`
        ).join('');
    }

    // Format qty: 0 decimal places for g/ml/szt, 2 for everything else
    function formatQty(value, unit) {
        if (value === null || value === undefined || !Number.isFinite(value)) return '—';
        const noDecUnits = ['g', 'ml', 'szt'];
        return noDecUnits.includes(String(unit ?? '').toLowerCase())
            ? Math.round(value).toLocaleString('en-US', {maximumFractionDigits: 0})
            : value.toFixed(2);
    }

    function portionSizeToKg(value, unit) {
        if (value === null || value === undefined || value <= 0) return null;
        if (unit === 'g')  return value / 1000.0;
        if (unit === 'kg') return value;
        return null;
    }

    function getRawMaterialPricingFromInputs() {
        if (!IS_WEIGHT_RECIPE || RAW_MAT_PRICE_PER_KG === null) {
            return {
                pricePerKg: null,
                perPortion: null,
                perPackaging: null,
                perCarton: null,
                portionWeightKg: null,
            };
        }

        const portionSize = parseDecimalOrNull(el('suPortionSize').value);
        const portionUnit = el('suPortionUnit').value;
        const ppp         = parseIntOrNull(el('suPortionsPerPack').value);
        const ppc         = parseIntOrNull(el('suPacksPerCarton').value);
        const portionWeightKg = portionSizeToKg(portionSize, portionUnit);
        const perPortion = portionWeightKg !== null ? RAW_MAT_PRICE_PER_KG * portionWeightKg : null;
        const perPackaging = (perPortion !== null && ppp !== null && ppp > 0) ? perPortion * ppp : null;
        const perCarton = (perPackaging !== null && ppc !== null && ppc > 0) ? perPackaging * ppc : null;

        return {
            pricePerKg: RAW_MAT_PRICE_PER_KG,
            perPortion,
            perPackaging,
            perCarton,
            portionWeightKg,
        };
    }

    function recomputeRawMaterialPricing() {
        const unavailable = el('rmPricingUnavailable');
        const grid = el('rmPricingGrid');
        const derivedHint = el('rmPricingDerivedHint');
        const pricing = getRawMaterialPricingFromInputs();

        if (!IS_WEIGHT_RECIPE || pricing.pricePerKg === null) {
            unavailable.classList.remove('d-none');
            grid.classList.add('d-none');
            derivedHint.classList.add('d-none');
            return pricing;
        }

        unavailable.classList.add('d-none');
        grid.classList.remove('d-none');
        el('rmPricePerKgOut').textContent = pricing.pricePerKg.toFixed(4) + ' ' + CURRENCY;

        if (pricing.perPortion !== null) {
            el('rmCostPerPortionOut').textContent = pricing.perPortion.toFixed(4) + ' ' + CURRENCY;
        } else {
            el('rmCostPerPortionOut').innerHTML = '<span class="text-muted">—</span>';
        }

        if (pricing.perPackaging !== null) {
            el('rmCostPerPackagingOut').textContent = pricing.perPackaging.toFixed(4) + ' ' + CURRENCY;
        } else {
            el('rmCostPerPackagingOut').innerHTML = '<span class="text-muted">—</span>';
        }

        if (pricing.perCarton !== null) {
            el('rmCostPerCartonOut').textContent = pricing.perCarton.toFixed(4) + ' ' + CURRENCY;
        } else {
            el('rmCostPerCartonOut').innerHTML = '<span class="text-muted">—</span>';
        }

        if (pricing.portionWeightKg !== null) {
            derivedHint.classList.add('d-none');
        } else {
            derivedHint.classList.remove('d-none');
        }

        return pricing;
    }

    // -----------------------------------------------------------------------
    //  Tile 1 — Product
    // -----------------------------------------------------------------------
    function updateProductPreview() {
        const sel = el('calcProductId');
        const val = sel.value;

        if (!val) {
            el('productPreviewCard').classList.add('d-none');
            return;
        }

        const p = productMap.get(String(val));
        if (!p) return;

        const initials = (p.name || '--').replace(/[^a-zA-ZÀ-ÖØ-öø-ÿ0-9 ]/g, '')
                            .trim().split(/\s+/).map(w => w[0]).join('').slice(0, 2).toUpperCase();

        el('productAvatar').textContent     = initials || '--';
        el('productName').textContent       = p.name || '';
