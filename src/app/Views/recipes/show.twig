            const editId = el('qrmCatEditId').value;
            el('qrmErrCategoryName').textContent = '';
            if (!name) {
                el('qrmErrCategoryName').textContent = '{{ translations.field_required }}';
                return;
            }
            try {
                let resp;
                if (editId) {
                    resp = await api(`/ajax/raw-material-categories/${editId}`, { method: 'PATCH', data: { name } });
                } else {
                    resp = await api('/ajax/raw-material-categories', { method: 'POST', data: { name } });
                }
                if (!(resp.ok || resp.success)) {
                    el('qrmErrCategoryName').textContent = {{ translations.category_name_exists|json_encode|raw }};
                    return;
                }
                const fresh = await api('/ajax/raw-material-categories');
                qrmCategories = Array.isArray(fresh.data) ? fresh.data : [];
                renderQrmCategoryList();
                rebuildCategorySelect();
                el('qrmCatEditId').value = '';
