                                </div>
                                <div class="row g-2 align-items-end">
                                    <div class="col-12 col-sm-4">
                                        <label class="form-label small mb-1">{{ translations.package_price }}</label>
                                        <div class="input-group input-group-sm">
                                            <input type="number" step="0.01" min="0.01" class="form-control" id="qrmInitPackagePrice">
                                            <span class="input-group-text" id="qrmInitPriceCurrency">{{ currency }}</span>
                                        </div>
                                    </div>
                                    <div class="col-12 col-sm-4">
                                        <label class="form-label small mb-1">{{ translations.package_qty }}</label>
                                        <div class="input-group input-group-sm">
                                            <input type="number" step="0.001" min="0.001" class="form-control" id="qrmInitPackageQty" value="1">
                                            <span class="input-group-text" id="qrmInitPackageUnit">—</span>
                                        </div>
