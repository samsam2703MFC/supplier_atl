    // -----------------------------------------------------------------------
    //  Tile 8 — Vidanges (live calc + save)
    // -----------------------------------------------------------------------
    function recomputeVidanges() {
        const deposit       = parseDecimalOrNull(el('vidDepositPerCarton').value);
        const packsPerCart  = parseIntOrNull(el('suPacksPerCarton').value);
        const portionsPerPkg = parseIntOrNull(el('suPortionsPerPack').value);

        const packOut    = el('vidDepositPerPackOut');
        const portionOut = el('vidDepositPerPortionOut');

        let depPerPack = null;
        if (deposit !== null && deposit >= 0 && packsPerCart !== null && packsPerCart > 0) {
            depPerPack = deposit / packsPerCart;
            packOut.textContent = depPerPack.toFixed(2) + ' ' + CURRENCY;
        } else {
            packOut.innerHTML = '<span class="text-muted">—</span>';
        }

        if (depPerPack !== null && portionsPerPkg !== null && portionsPerPkg > 0) {
            portionOut.textContent = (depPerPack / portionsPerPkg).toFixed(2) + ' ' + CURRENCY;
        } else {
            portionOut.innerHTML = '<span class="text-muted">—</span>';
        }
    }

    el('vidDepositPerCarton').addEventListener('input', recomputeVidanges);
    // Recalculate when sales unit inputs change
    el('suPortionsPerPack').addEventListener('input', recomputeVidanges);
    el('suPacksPerCarton').addEventListener('input',  recomputeVidanges);

    el('btnSaveVidanges').addEventListener('click', async () => {
