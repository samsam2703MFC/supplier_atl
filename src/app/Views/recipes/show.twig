                        <button type="button" class="btn btn-primary" id="qrmBtnSaveCategory">
                            <i class="bi bi-check-lg"></i>
                        </button>
                        <button type="button" class="btn btn-light" id="qrmBtnCancelCatEdit" style="display:none;">
