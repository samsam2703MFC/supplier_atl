{% extends "layouts/base.twig" %}

{% block title %}{{ recipe.name }} — {{ translations.calculator_subtitle }}{% endblock %}

{% block head %}
<style>
.calc-tile-num {
    width: 28px; height: 28px;
    border-radius: 50%;
    background: #6366F1;
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 700;
    flex-shrink: 0;
}
.calc-product-card {
    border: 1px solid #E2E8F0;
    border-radius: 8px;
    padding: 14px 16px;
    background: #F8FAFC;
}
.calc-product-avatar {
    width: 52px; height: 52px;
    border-radius: 8px;
    background: #EEF2FF;
    color: #3730A3;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    font-weight: 700;
    flex-shrink: 0;
}
.calc-ing-table th,.calc-ing-table td { vertical-align: middle; }
.calc-ing-table .num { font-variant-numeric: tabular-nums; }
.calc-empty { text-align: center; padding: 48px 16px; color: #94A3B8; }
.calc-empty i { font-size: 32px; opacity: .4; display: block; margin-bottom: 8px; }
.calc-no-price { color: #EF4444; font-size: 10px; font-weight: 600; }
.calc-action-btn {
    width: 28px; height: 28px;
    border-radius: 6px;
    border: 1px solid #E2E8F0;
    background: #fff;
    color: #94A3B8;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: all .15s;
    font-size: 12px;
}
.calc-action-btn:hover { background: #EF4444; color: #fff; border-color: #EF4444; }
.calc-allergen-badge {
    display: inline-flex;
    align-items: center;
    background: #FEF3C7;
    color: #92400E;
    border: 1px solid #FDE68A;
    padding: 3px 10px;
    border-radius: 12px;
    font-size: 12px;
    font-weight: 600;
    margin: 2px;
}
.calc-add-form-bar { background: #F8FAFC; border-bottom: 1px solid #E2E8F0; padding: 12px 16px; }
.is-archived-badge { display: inline-block; background: #F1F5F9; color: #94A3B8; padding: 2px 8px; border-radius: 20px; font-size: 10px; font-weight: 600; margin-left: 4px; }
.calc-page-wrap { max-width: 900px; margin: 0 auto; }
.calc-summary-banner {
    background: linear-gradient(135deg, #EEF2FF 0%, #E0E7FF 100%);
    border: 1px solid #C7D2FE;
    border-radius: 12px;
    padding: 16px 20px;
}
.calc-summary-icon {
    width: 40px; height: 40px;
    background: #6366F1;
    color: #fff;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    flex-shrink: 0;
}
.calc-summary-text { color: #374151; font-size: 14px; line-height: 1.7; }
.calc-summary-text strong { color: #3730A3; }
.calc-summary-text .text-success strong { color: #059669 !important; }
</style>
{% endblock %}

{% block page_heading %}
    <div class="page-heading" style="max-width: 900px; margin: 0 auto;">
        <div class="mb-1">
            <a href="{{ ROOT }}/recipes" class="text-muted small text-decoration-none">
                <i class="bi bi-arrow-left me-1"></i>{{ translations.back_to_recipes }}
            </a>
        </div>
        <h3>
            {{ recipe.name }}
            {% if recipe.is_archived %}
                <span class="is-archived-badge">{{ translations.archived }}</span>
            {% endif %}
        </h3>
        <p class="text-subtitle text-muted">{{ translations.calculator_subtitle }}</p>
    </div>
{% endblock %}

{% block content %}
<div class="calc-page-wrap">

    {# ===== TILE 1: PRODUKT ===== #}
    <div class="card mb-3">
        <div class="card-header d-flex align-items-center justify-content-between gap-2">
            <div class="d-flex align-items-center gap-2">
                <span class="calc-tile-num">1</span>
                <span class="fw-semibold">{{ translations.product_tile_title }}</span>
            </div>
            <div class="d-flex gap-2">
                {% if recipe.product_id %}
                    <a href="{{ ROOT }}/catalog" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-box-arrow-up-right me-1"></i>{{ translations.open_in_catalog }}
                    </a>
                {% endif %}
            </div>
        </div>
        <div class="card-body">

            <div class="col-12 col-md-8">
                <label class="form-label">{{ translations.select_product_label }}</label>
                <select id="calcProductId" class="form-select">
                    <option value="">{{ translations.recipe_select_product }}</option>
                    {% for p in products %}
                        <option value="{{ p.id }}"
                                data-name="{{ p.name }}"
                                data-sku="{{ p.sku ?? '' }}"
                                data-active="{{ p.is_active ? '1' : '0' }}"
                                {{ recipe.product_id == p.id ? 'selected' : '' }}>
                            {{ p.name }}{% if p.sku %} ({{ p.sku }}){% endif %}
                        </option>
                    {% endfor %}
                </select>
                <div class="form-text">{{ translations.recipe_product_hint }}</div>
            </div>

            {# Karta podglądu produktu #}
            <div id="productPreviewCard" class="mt-3 {{ recipe.product_id ? '' : 'd-none' }}">
                <div class="calc-product-card d-flex align-items-center gap-3">
                    <div class="calc-product-avatar" id="productAvatar">
                        {{ recipe.product_name ? (recipe.product_name|slice(0, 2)|upper) : '--' }}
                    </div>
                    <div class="flex-grow-1 min-width-0">
                        <div class="fw-semibold fs-5" id="productName">{{ recipe.product_name ?? '' }}</div>
                        <div class="text-muted small mt-1">
                            {{ translations.product_preview_sku }}:
                            <strong id="productSku">{{ recipe.product_sku ?? translations.product_no_sku }}</strong>
                        </div>
                    </div>
                    <span id="productStatusBadge"
                          class="badge {{ recipe.product_is_active ? 'bg-success' : 'bg-secondary' }}">
                        {{ recipe.product_is_active ? translations.product_preview_status_active : translations.product_preview_status_inactive }}
                    </span>
                </div>
            </div>

        </div>
        {# <div class="card-footer text-end">
            <button class="btn btn-sm btn-primary" id="btnSaveProduct">
                <i class="bi bi-check-lg me-1"></i>{{ translations.save }}
            </button>
        </div> #}
    </div>

    {# ===== TILE 2: SUROWCE ===== #}
    <div class="card mb-3">
        <div class="card-header d-flex align-items-center justify-content-between gap-2">
            <div class="d-flex align-items-center gap-2">
                <span class="calc-tile-num">2</span>
                <span class="fw-semibold">{{ translations.raw_materials_tile_title }}</span>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-outline-secondary" id="btnOpenQuickAddRm" title="{{ translations.quick_add_raw_material }}">
                    <i class="bi bi-plus-circle me-1"></i>{{ translations.quick_add_raw_material }}
                </button>
                <button class="btn btn-sm btn-outline-primary" id="btnToggleAddIngredient">
                    <i class="bi bi-plus-lg me-1"></i>{{ translations.add_ingredient }}
                </button>
            </div>
        </div>

        {# Formularz dodawania składnika #}
        <div id="addIngredientForm" class="calc-add-form-bar" style="display:none;">
            <div class="row g-2 align-items-end">
                <div class="col-12 col-md-6">
                    <label class="form-label small mb-1">
                        {{ translations.ingredient_name }} <span class="text-danger">*</span>
                    </label>
                    <select class="form-select form-select-sm" id="newRawMaterialId">
                        <option value="">{{ translations.select_raw_material }}</option>
                        {% for rm in rawMaterials %}
                            <option value="{{ rm.id }}" data-unit="{{ rm.unit_name ?? rm.unit_symbol ?? '' }}">
                                {{ rm.name }}{% if rm.unit_name %} ({{ rm.unit_name }}){% endif %}
                            </option>
                        {% endfor %}
                    </select>
                    <div class="invalid-feedback d-block small" id="errIngRm"></div>
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label small mb-1">
                        {{ translations.quantity }} <span class="text-danger">*</span>
                    </label>
                    <div class="input-group input-group-sm">
                        <input type="number" step="0.001" min="0.001" class="form-control" id="newQty">
                        <span class="input-group-text" id="newQtyUnit">—</span>
                    </div>
                    <div class="invalid-feedback d-block small" id="errIngQty"></div>
                </div>
                <div class="col-12 col-md-2 d-flex gap-1">
                    <button type="button" class="btn btn-sm btn-success flex-grow-1" id="btnConfirmAddIngredient">
                        <i class="bi bi-plus"></i>
                    </button>
                    <button type="button" class="btn btn-sm btn-light" id="btnCancelAddIngredient">
                        <i class="bi bi-x"></i>
                    </button>
                </div>
            </div>
        </div>

        {# Tabela składników #}
        <div class="table-responsive">
            <table class="table table-hover calc-ing-table mb-0">
                <thead class="table-light">
                    <tr>
                        <th>{{ translations.ingredient_name }}</th>
                        <th style="width:130px;" class="text-end">{{ translations.ingredients_qty_header }}</th>
                        <th style="width:110px;" class="text-end">{{ translations.ingredients_price_header }}</th>
                        <th style="width:60px;"  class="text-end">%</th>
                        <th style="width:120px;" class="text-end">{{ translations.ingredients_cost_header }}</th>
                        <th style="width:40px;"></th>
                    </tr>
                </thead>
                <tbody id="ingredientsTbody">
                    {% if ingredients is empty %}
                        <tr>
                            <td colspan="6" class="calc-empty">
                                <i class="bi bi-basket2"></i>{{ translations.no_results }}
                            </td>
                        </tr>
                    {% else %}
                        {% set tw = summary.total_weight ?? 0 %}
                        {% for ing in ingredients %}
                            <tr data-ing-id="{{ ing.id }}">
                                <td>
                                    {{ ing.raw_material_name_snapshot }}
                                    {% if ing.raw_material_is_archived %}
                                        <span class="calc-no-price ms-1" title="{{ translations.ingredient_archived_warning }}">
                                            <i class="bi bi-archive"></i>
                                        </span>
                                    {% endif %}
                                </td>
                                <td class="text-end num">
                                    {% set _noDecUnits = ['g', 'ml', 'szt'] %}
                                    {% if ing.unit_symbol_snapshot in _noDecUnits %}
                                        {{ ing.quantity|number_format(0, '.', '') }}
                                    {% else %}
                                        {{ ing.quantity|number_format(2, '.', '') }}
                                    {% endif %}
                                    <span class="text-muted small"> {{ ing.unit_symbol_snapshot }}</span>
                                </td>
                                <td class="text-end num">
                                    {% if ing.price_net_snapshot is not null %}
                                        {{ ing.price_net_snapshot|number_format(2, '.', '') }}
                                    {% else %}
                                        <span class="calc-no-price" title="{{ translations.ingredient_no_price }}">—</span>
                                    {% endif %}
                                </td>
                                <td class="text-end num">
                                    {% if tw > 0 %}
                                        {{ (ing.quantity / tw * 100)|number_format(2, '.', '') }}%
                                    {% else %}
                                        —
                                    {% endif %}
                                </td>
                                <td class="text-end num">
                                    {% if ing.price_net_snapshot is not null %}
                                        {{ (ing.quantity * ing.price_net_snapshot * (1 + (ing.waste_perc_snapshot ?? 0) / 100))|number_format(2, '.', '') }}
                                    {% else %}
                                        <span class="calc-no-price">—</span>
                                    {% endif %}
                                </td>
                                <td class="text-end">
                                    <button class="calc-action-btn btnDeleteIng"
                                            data-id="{{ ing.id }}"
                                            title="{{ translations.delete }}">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        {% endfor %}
                    {% endif %}
                </tbody>
                {% if ingredients is not empty %}
                <tfoot class="table-light">
                    <tr>
                        <td colspan="2" class="small text-muted py-2">
                            {{ ingredients|length }} {{ translations.summary_ingredients }}
                            · {% set _twUnit = ingredients[0].unit_symbol_snapshot ?? '' %}{% if _twUnit in ['g','ml','szt'] %}{{ (summary.total_weight ?? 0)|number_format(0, '.', '') }}{% else %}{{ (summary.total_weight ?? 0)|number_format(2, '.', '') }}{% endif %}
                            {{ _twUnit }} {{ translations.summary_total_weight|lower }}
                        </td>
                        <td></td>
                        <td class="text-end fw-semibold text-primary small py-2">100%</td>
                        <td class="text-end fw-bold py-2" id="totalCostCell">
                            {% if summary.total_cost is not null %}
                                {{ summary.total_cost|number_format(2, '.', '') }} {{ currency }}
                            {% else %}
                                <span class="calc-no-price">—</span>
                            {% endif %}
                        </td>
                        <td></td>
                    </tr>
                </tfoot>
                {% endif %}
            </table>
        </div>

        {# Totals row (mockup-style) #}
        {% if ingredients is not empty %}
        <div class="d-flex justify-content-between align-items-center px-3 py-2 border-top bg-light">
            <span class="small text-muted">
                {{ ingredients|length }} {{ translations.summary_ingredients }}
                · {% set _twUnit2 = ingredients[0].unit_symbol_snapshot ?? '' %}{% if _twUnit2 in ['g','ml','szt'] %}{{ (summary.total_weight ?? 0)|number_format(0, '.', '') }}{% else %}{{ (summary.total_weight ?? 0)|number_format(2, '.', '') }}{% endif %} {{ _twUnit2 }}
            </span>
            <span class="small">
                {{ translations.total_raw_materials }}
                <strong class="ms-2 fs-6">
                    {% if summary.total_cost is not null %}
                        {{ summary.total_cost|number_format(2, '.', '') }} {{ currency }}
                    {% else %}
                        <span class="calc-no-price">—</span>
                    {% endif %}
                </strong>
            </span>
        </div>
        {% endif %}

        {# Alergeny #}
        <div class="px-3 py-3 border-top">
            <div class="text-muted small fw-semibold text-uppercase mb-1">
                {{ translations.allergens_section }} —
                <span class="fw-normal text-lowercase">{{ translations.allergens_hint }}</span>
            </div>
            <div id="allergensBadges" class="mt-2">
                {% if summary.allergens is empty %}
                    <span class="text-muted small">{{ translations.no_allergens }}</span>
                {% else %}
                    {% set _seenAllergens = [] %}
                    {% for a in summary.allergens %}
                        {% set _allergenKey = a.code ?? a.name ?? '' %}
                        {% if _allergenKey not in _seenAllergens %}
                            {% set _seenAllergens = _seenAllergens|merge([_allergenKey]) %}
                            {% set _allergenLabel = translations['allergen_' ~ _allergenKey] ?? a.name ?? _allergenKey %}
                            <span class="calc-allergen-badge">
                                <i class="bi bi-exclamation-diamond me-1"></i>{{ _allergenLabel }}
                            </span>
                        {% endif %}
                    {% endfor %}
                {% endif %}
            </div>
        </div>

        {# Notatki technologiczne #}
        <div class="px-3 py-3 border-top">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="text-muted small fw-semibold text-uppercase">
                    {{ translations.technical_notes }}
                </div>
                <button class="btn btn-sm btn-primary" id="btnSaveNotes">
                    <i class="bi bi-check-lg me-1"></i>{{ translations.save_technical_notes }}
                </button>
            </div>
            <textarea class="form-control" id="calcTechnicalNotes" rows="4" maxlength="5000"
                      placeholder="{{ translations.technical_notes_placeholder }}">{{ recipe.technical_notes ?? '' }}</textarea>
            <div class="form-text">{{ translations.technical_notes_hint }}</div>
        </div>

    </div>

    {# ===== SUMMARY AFTER TILE 2 ===== #}
    {% set rmPricing = recipe.raw_material_pricing ?? {} %}
    {% if ingredients is not empty %}
    {% set _sum_g   = 0 %}
    {% set _sum_ml  = 0 %}
    {% set _sum_szt = 0 %}
    {% for _si in ingredients %}
        {% if _si.unit_symbol_snapshot == 'g' %}
            {% set _sum_g = _sum_g + _si.quantity %}
        {% elseif _si.unit_symbol_snapshot == 'ml' %}
            {% set _sum_ml = _sum_ml + _si.quantity %}
        {% elseif _si.unit_symbol_snapshot == 'szt' %}
            {% set _sum_szt = _sum_szt + _si.quantity %}
        {% endif %}
    {% endfor %}
    <div class="calc-summary-banner mb-3">
        <div class="d-flex align-items-start gap-3">
            <div class="calc-summary-icon flex-shrink-0">
                <i class="bi bi-clipboard2-check"></i>
            </div>
            <div class="flex-grow-1">
                <div class="fw-semibold text-indigo-800 mb-1">{{ translations.summary_step2_title }}</div>
                <div class="calc-summary-text">
                    {{ translations.summary_recipe_intro }}
                    {% set _sum_parts = [] %}
                    {% if _sum_g > 0 %}
                        {% set _sum_parts = _sum_parts|merge(['<strong>' ~ _sum_g|number_format(0, '.', '') ~ ' g</strong>']) %}
                    {% endif %}
                    {% if _sum_ml > 0 %}
                        {% set _sum_parts = _sum_parts|merge(['<strong>' ~ _sum_ml|number_format(0, '.', '') ~ ' ml</strong>']) %}
                    {% endif %}
                    {% if _sum_szt > 0 %}
                        {% set _sum_parts = _sum_parts|merge(['<strong>' ~ _sum_szt|number_format(0, '.', '') ~ ' szt</strong>']) %}
                    {% endif %}
                    {% if _sum_parts is empty %}
                        <strong>{{ (summary.total_weight ?? 0)|number_format(2, '.', '') }} {{ ingredients[0].unit_symbol_snapshot ?? '' }}</strong>
                    {% else %}
                        {% for _part in _sum_parts %}
                            {{ _part|raw }}{% if not loop.last %} {{ translations.summary_and }} {% endif %}
                        {% endfor %}
                    {% endif %}
                    {% if summary.total_cost is not null %}
                        — {{ translations.summary_cost_intro }}
                        <span class="text-success fw-bold">{{ summary.total_cost|number_format(2, '.', '') }} {{ currency }}</span>.
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
    {% endif %}

    {% if rmPricing.price_per_kg is not null %}
    <div class="calc-summary-banner mb-3">
        <div class="d-flex align-items-start gap-3">
            <div class="calc-summary-icon flex-shrink-0">
                <i class="bi bi-box-seam"></i>
            </div>
            <div class="flex-grow-1">
                <div class="fw-semibold text-indigo-800 mb-1">{{ translations.price_per_kg_tile_title }}</div>
                <div class="calc-summary-text">
                    {{ translations.summary_cost_per_kg_intro }}
                    <span class="text-success fw-bold">{{ rmPricing.price_per_kg|number_format(4, '.', '') }} {{ currency }}</span>.
                </div>
            </div>
        </div>
    </div>
    {% endif %}

    {# ===== TILE 3: PRICE PER KG ===== #}
    <div class="card mb-3">
        <div class="card-header d-flex align-items-center gap-2">
            <span class="calc-tile-num">3</span>
            <span class="fw-semibold">{{ translations.price_per_kg_tile_title }}</span>
        </div>
        <div class="card-body">
            <div id="rmPricingUnavailable" class="alert alert-warning d-flex align-items-center gap-2 {% if rmPricing.is_weight_recipe %}d-none{% endif %}" role="alert">
                <i class="bi bi-exclamation-triangle-fill flex-shrink-0"></i>
                <span>{{ translations.price_per_kg_unavailable }}</span>
            </div>

            <div class="row g-3{% if not rmPricing.is_weight_recipe %} d-none{% endif %}" id="rmPricingGrid">
                <div class="col-12 col-md-3">
                    <div class="border rounded p-3 bg-light h-100">
                        <div class="text-muted small text-uppercase">{{ translations.price_per_kg_label }}</div>
                        <div class="fw-bold fs-5 text-primary" id="rmPricePerKgOut">
                            {% if rmPricing.price_per_kg is not null %}
                                {{ rmPricing.price_per_kg|number_format(4, '.', '') }} {{ currency }}
                            {% else %}<span class="text-muted">—</span>{% endif %}
                        </div>
                    </div>
                </div>
                <div class="col-12 col-md-3">
                    <div class="border rounded p-3 bg-light h-100">
                        <div class="text-muted small text-uppercase">{{ translations.raw_material_cost_per_portion_label }}</div>
                        <div class="fw-bold fs-5 text-primary" id="rmCostPerPortionOut">
                            {% if rmPricing.raw_materials_per_portion is not null %}
                                {{ rmPricing.raw_materials_per_portion|number_format(4, '.', '') }} {{ currency }}
                            {% else %}<span class="text-muted">—</span>{% endif %}
                        </div>
                    </div>
                </div>
                <div class="col-12 col-md-3">
                    <div class="border rounded p-3 bg-light h-100">
                        <div class="text-muted small text-uppercase">{{ translations.raw_material_cost_per_packaging_label }}</div>
                        <div class="fw-bold fs-5 text-primary" id="rmCostPerPackagingOut">
                            {% if rmPricing.raw_materials_per_packaging is not null %}
                                {{ rmPricing.raw_materials_per_packaging|number_format(4, '.', '') }} {{ currency }}
                            {% else %}<span class="text-muted">—</span>{% endif %}
                        </div>
                    </div>
                </div>
                <div class="col-12 col-md-3">
                    <div class="border rounded p-3 bg-light h-100">
                        <div class="text-muted small text-uppercase">{{ translations.raw_material_cost_per_carton_label }}</div>
                        <div class="fw-bold fs-5 text-primary" id="rmCostPerCartonOut">
                            {% if rmPricing.raw_materials_per_carton is not null %}
                                {{ rmPricing.raw_materials_per_carton|number_format(4, '.', '') }} {{ currency }}
                            {% else %}<span class="text-muted">—</span>{% endif %}
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-text mt-3" id="rmPricingHint">
                {{ translations.price_per_kg_hint }}
            </div>
            <div class="form-text mt-2{% if not rmPricing.is_weight_recipe or rmPricing.raw_materials_per_portion is not null %} d-none{% endif %}" id="rmPricingDerivedHint">
                {{ translations.price_per_kg_missing_sales_weight_unit }}
            </div>
        </div>
    </div>

    {# ===== TILE 4: SALES UNIT ===== #}
    {% set su = recipe.sales_unit %}
    {# Default portion_unit is resolved in PHP (RecipeController::resolveDefaultPortionUnit) #}
    {% set _portionUnit = defaultPortionUnit %}
    <div class="card mb-3">
        <div class="card-header d-flex align-items-center gap-2">
            <span class="calc-tile-num">4</span>
            <span class="fw-semibold">{{ translations.sales_unit_tile_title }}</span>
        </div>
        <div class="card-body">
            <div class="row g-3 align-items-start">
                <div class="col-12 col-md-4">
                    <label class="form-label">{{ translations.sales_unit_portion_size }}</label>
                    <div class="input-group">
                        <input type="number"
                               step="0.001"
                               min="0"
                               class="form-control"
                               id="suPortionSize"
                               value="{{ su.portion_size is not null ? su.portion_size : '' }}">
                        <select class="form-select" id="suPortionUnit" style="max-width: 90px;">
                            <option value="g"   {% if _portionUnit == 'g'   %}selected{% endif %}>g</option>
                            <option value="ml"  {% if _portionUnit == 'ml'  %}selected{% endif %}>ml</option>
                            <option value="szt" {% if _portionUnit == 'szt' or _portionUnit == 'pcs' %}selected{% endif %}>szt</option>
                            <option value="kg"  {% if _portionUnit == 'kg'  %}selected{% endif %}>kg</option>
                            <option value="l"   {% if _portionUnit == 'l'   %}selected{% endif %}>l</option>
                        </select>
                    </div>
                    <div class="invalid-feedback d-block small" id="errSuPortionSize"></div>
                    <div class="invalid-feedback d-block small" id="errSuPortionUnit"></div>
                    <div class="form-text">{{ translations.sales_unit_portion_size_hint }}</div>
                </div>

                <div class="col-12 col-md-4">
                    <label class="form-label">{{ translations.sales_unit_portions_per_packaging }}</label>
                    <input type="number"
                           step="1"
                           min="1"
                           class="form-control"
                           id="suPortionsPerPack"
                           value="{{ su.portions_per_packaging is not null ? su.portions_per_packaging : '' }}">
                    <div class="invalid-feedback d-block small" id="errSuPortionsPerPack"></div>
                    <div class="form-text">{{ translations.sales_unit_portions_per_packaging_hint }}</div>
                </div>

                <div class="col-12 col-md-4">
                    <label class="form-label">{{ translations.sales_unit_packagings_per_carton }}</label>
                    <input type="number"
                           step="1"
                           min="1"
                           class="form-control"
                           id="suPacksPerCarton"
                           value="{{ su.packagings_per_carton is not null ? su.packagings_per_carton : '' }}">
                    <div class="invalid-feedback d-block small" id="errSuPacksPerCarton"></div>
                    <div class="form-text">{{ translations.sales_unit_packagings_per_carton_hint }}</div>
                </div>
            </div>

            <div class="row g-3 mt-1">
                <div class="col-12 col-md-4">
                    <div class="border rounded p-3 bg-light h-100">
                        <div class="text-muted small text-uppercase">{{ translations.sales_unit_portions_per_carton }}</div>
                        <div class="fw-bold fs-5 text-primary" id="suPortionsPerCartonOut">
                            {% if su.portions_per_carton is not null %}{{ su.portions_per_carton }}{% else %}<span class="text-muted">—</span>{% endif %}
                        </div>
                    </div>
                </div>
                <div class="col-12 col-md-4">
                    <div class="border rounded p-3 bg-light h-100">
                        <div class="text-muted small text-uppercase">{{ translations.sales_unit_packaging_weight }}</div>
                        <div class="fw-bold fs-5 text-primary" id="suPackWeightOut">
                            {% if su.packaging_size is not null %}
                                {% set _puUnit = su.portion_unit ?? _portionUnit %}
                                {% if _puUnit in ['g','ml','szt'] %}{{ su.packaging_size|number_format(0, '.', '') }}{% else %}{{ su.packaging_size|number_format(2, '.', '') }}{% endif %} {{ _puUnit }}
                            {% else %}<span class="text-muted">—</span>{% endif %}
                        </div>
                    </div>
                </div>
                <div class="col-12 col-md-4">
                    <div class="border rounded p-3 bg-light h-100">
                        <div class="text-muted small text-uppercase">{{ translations.sales_unit_carton_weight }}</div>
                        <div class="fw-bold fs-5 text-primary" id="suCartonWeightOut">
                            {% if su.carton_weight_kg is not null %}
                                {{ su.carton_weight_kg|number_format(2, '.', '') }} kg
                            {% elseif su.carton_size is not null %}
                                {% set _puUnit2 = su.portion_unit ?? _portionUnit %}
                                {% if _puUnit2 in ['g','ml','szt'] %}{{ su.carton_size|number_format(0, '.', '') }}{% else %}{{ su.carton_size|number_format(2, '.', '') }}{% endif %} {{ _puUnit2 }}
                            {% else %}<span class="text-muted">—</span>{% endif %}
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-text mt-3">
                {{ translations.sales_unit_hierarchy_hint }}
            </div>
            <div id="suYieldWarning" class="alert alert-warning d-flex align-items-center gap-2 mt-3 d-none" role="alert">
                <i class="bi bi-exclamation-triangle-fill flex-shrink-0"></i>
                <span id="suYieldWarningText"></span>
            </div>
        </div>
        <div class="card-footer text-end">
            <button class="btn btn-sm btn-primary" id="btnSaveSalesUnit">
                <i class="bi bi-check-lg me-1"></i>{{ translations.save }}
            </button>
        </div>
    </div>

    {# ===== TILE 5: LABOR ===== #}
    <div class="card mb-3">
        <div class="card-header d-flex align-items-center justify-content-between gap-2">
            <div class="d-flex align-items-center gap-2">
                <span class="calc-tile-num">5</span>
                <span class="fw-semibold">{{ translations.labor_tile_title }}</span>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-outline-secondary" id="btnOpenLaborDefaults" title="{{ translations.labor_defaults_btn }}">
                    <i class="bi bi-gear me-1"></i>{{ translations.labor_defaults_btn }}
                </button>
                {% set _hasNoLaborValues = recipe.labor_time_per_unit_min is null and recipe.labor_hourly_rate is null %}
                {% set _hasLaborDefaults = laborDefaults is defined and (laborDefaults.labor_time_default is not null or laborDefaults.labor_rate_default is not null) %}
                {% if _hasNoLaborValues and _hasLaborDefaults %}
                <button class="btn btn-sm btn-outline-secondary" id="btnLoadLaborDefaults">
                    <i class="bi bi-download me-1"></i>{{ translations.labor_defaults_load_btn }}
                </button>
                {% endif %}
            </div>
        </div>
        <div class="card-body">
            <div class="row g-3 align-items-start">
                <div class="col-12 col-md-4">
                    <label class="form-label">{{ translations.labor_time_per_unit }}</label>
                    <div class="input-group">
                        <input type="number"
                               step="0.1"
                               min="0"
                               max="9999.99"
                               class="form-control"
                               id="laborTime"
                               value="{{ recipe.labor_time_per_unit_min is not null ? recipe.labor_time_per_unit_min : '' }}">
                        <span class="input-group-text">{{ translations.labor_unit_min }}</span>
                    </div>
                    <div class="invalid-feedback d-block small" id="errLaborTime"></div>
                    <div class="form-text">{{ translations.labor_time_hint }}</div>
                </div>

                <div class="col-12 col-md-4">
                    <label class="form-label">{{ translations.labor_hourly_rate }}</label>
                    <div class="input-group">
                        <input type="number"
                               step="0.01"
                               min="0"
                               max="9999999.99"
                               class="form-control"
                               id="laborRate"
                               value="{{ recipe.labor_hourly_rate is not null ? recipe.labor_hourly_rate : '' }}">
                        <span class="input-group-text">{{ currency }}/h</span>
                    </div>
                    <div class="invalid-feedback d-block small" id="errLaborRate"></div>
                    <div class="form-text">{{ translations.labor_rate_hint }}</div>
                </div>

                <div class="col-12 col-md-4">
                    <label class="form-label">{{ translations.labor_cost_per_unit }}</label>
                    <div class="form-control bg-light fw-bold text-primary fs-5"
                         id="laborCostOut"
                         style="text-align: right;">
                        {% if recipe.labor_cost_per_unit is not null %}
                            {{ recipe.labor_cost_per_unit|number_format(2, '.', '') }} {{ currency }}
                        {% else %}
                            <span class="text-muted">—</span>
                        {% endif %}
                    </div>
                    <div class="form-text">{{ translations.labor_cost_hint }}</div>
                </div>
            </div>
        </div>
        <div class="card-footer text-end">
            <button class="btn btn-sm btn-primary" id="btnSaveLabor">
                <i class="bi bi-check-lg me-1"></i>{{ translations.save }}
            </button>
        </div>
    </div>

    {# ===== LABOR SUMMARY ===== #}
    {% if recipe.labor_time_per_unit_min is not null or recipe.labor_cost_per_unit is not null %}
    <div class="calc-summary-banner mb-3">
        <div class="d-flex align-items-start gap-3">
            <div class="calc-summary-icon flex-shrink-0">
                <i class="bi bi-person-check"></i>
            </div>
            <div class="flex-grow-1">
                <div class="fw-semibold mb-1">{{ translations.labor_summary_title }}</div>
                <div class="calc-summary-text">
                    {{ translations.labor_summary_intro }}
                    {% if recipe.labor_time_per_unit_min is not null %}
                        <strong>{{ recipe.labor_time_per_unit_min|number_format(1, '.', '') }} {{ translations.labor_unit_min }}</strong>
                    {% else %}
                        <strong class="text-muted">—</strong>
                    {% endif %}
                    {{ translations.labor_summary_cost_intro }}
                    {% if recipe.labor_cost_per_unit is not null %}
                        <strong class="text-success">{{ recipe.labor_cost_per_unit|number_format(2, '.', '') }} {{ currency }}</strong>.
                    {% else %}
                        <strong class="text-muted">—</strong>.
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
    {% endif %}

    {# ===== TILE 5: OVERHEAD ===== #}
    {% set oh = recipe.overhead %}
    <div class="card mb-3">
        <div class="card-header d-flex align-items-center gap-2">
            <span class="calc-tile-num">6</span>
            <span class="fw-semibold">{{ translations.overhead_tile_title }}</span>
        </div>
        <div class="card-body">
            <div class="row g-3 align-items-start">
                <div class="col-12 col-md-4">
                    <label class="form-label">{{ translations.overhead_forecast_cartons }}</label>
                    <div class="input-group">
                        <input type="number"
                               step="1"
                               min="1"
                               class="form-control"
                               id="ohForecast"
                               value="{{ oh.forecast_cartons_per_month is not null ? oh.forecast_cartons_per_month : '' }}">
                        <span class="input-group-text">/ {{ translations.month_short }}</span>
                    </div>
                    <div class="invalid-feedback d-block small" id="errOhForecast"></div>
                    <div class="form-text">{{ translations.overhead_forecast_hint }}</div>
                </div>

                <div class="col-12 col-md-4">
                    <label class="form-label">{{ translations.overhead_pool }}</label>
                    <div class="input-group">
                        <input type="number"
                               step="0.01"
                               min="0"
                               class="form-control"
                               id="ohPool"
                               value="{{ oh.monthly_overhead_pool is not null ? oh.monthly_overhead_pool : '' }}">
                        <span class="input-group-text">{{ currency }}</span>
                    </div>
                    <div class="invalid-feedback d-block small" id="errOhPool"></div>
                    <div class="form-text">{{ translations.overhead_pool_hint }}</div>
                </div>

                <div class="col-12 col-md-4">
                    <label class="form-label">{{ translations.overhead_per_portion }}</label>
                    <div class="form-control bg-light fw-bold text-primary fs-5"
                         id="ohPerPortionOut"
                         style="text-align: right;">
                        {% if oh.overhead_per_portion is not null %}
                            {{ oh.overhead_per_portion|number_format(2, '.', '') }} {{ currency }}
                        {% else %}<span class="text-muted">—</span>{% endif %}
                    </div>
                    <div class="form-text">{{ translations.overhead_per_portion_hint }}</div>
                </div>
            </div>

            <button class="btn btn-outline-secondary btn-sm d-none" id="btnRecalcOverhead">
                <i class="bi bi-arrow-clockwise me-1"></i>{{ translations.overhead_recalculate }}
            </button>

            <div class="form-text mt-2" id="ohSourceInfo">
                {% if recipe.sales_unit.portions_per_carton is not null %}
                    {{ translations.overhead_based_on|replace({'{n}': recipe.sales_unit.portions_per_carton}) }}
                {% else %}
                    <span class="text-warning">{{ translations.overhead_missing_sales_unit }}</span>
                {% endif %}
            </div>
        </div>
        <div class="card-footer text-end">
            <button class="btn btn-sm btn-primary" id="btnSaveOverhead">
                <i class="bi bi-check-lg me-1"></i>{{ translations.save }}
            </button>
        </div>
    </div>

    {# ===== TILE 6: PACKAGING COST ===== #}
    {% set pack = recipe.packaging %}
    <div class="card mb-3">
        <div class="card-header d-flex align-items-center gap-2">
            <span class="calc-tile-num">7</span>
            <span class="fw-semibold">{{ translations.packaging_tile_title }}</span>
        </div>
        <div class="card-body">
            <div class="row g-3 align-items-start">
                <div class="col-12 col-md-6">
                    <label class="form-label">{{ translations.packaging_description }}</label>
                    <input type="text"
                           class="form-control"
                           id="packDesc"
                           maxlength="255"
                           value="{{ pack.description is not null ? pack.description : '' }}"
                           placeholder="{{ translations.packaging_description_placeholder }}">
                    <div class="invalid-feedback d-block small" id="errPackDesc"></div>
                    <div class="form-text">{{ translations.packaging_description_hint }}</div>
                </div>

                <div class="col-12 col-md-3">
                    <label class="form-label">{{ translations.packaging_cost_per_packaging }}</label>
                    <div class="input-group">
                        <input type="number"
                               step="0.0001"
                               min="0"
                               class="form-control"
                               id="packCost"
                               value="{{ pack.cost_per_packaging is not null ? pack.cost_per_packaging : '' }}">
                        <span class="input-group-text">{{ currency }}</span>
                    </div>
                    <div class="invalid-feedback d-block small" id="errPackCost"></div>
                    <div class="form-text">{{ translations.packaging_cost_hint }}</div>
                </div>

                <div class="col-12 col-md-3">
                    <label class="form-label">{{ translations.packaging_cost_per_portion }}</label>
                    <div class="form-control bg-light fw-bold text-primary fs-5"
                         id="packCostPerPortionOut"
                         style="text-align: right;">
                        {% if pack.cost_per_packaging is not null and recipe.sales_unit.portions_per_packaging is not null and recipe.sales_unit.portions_per_packaging > 0 %}
                            {{ (pack.cost_per_packaging / recipe.sales_unit.portions_per_packaging)|number_format(2, '.', '') }} {{ currency }}
                        {% else %}
                            <span class="text-muted">—</span>
                        {% endif %}
                    </div>
                    <div class="form-text">{{ translations.packaging_cost_per_portion_hint }}</div>
                </div>
            </div>
        </div>
        <div class="card-footer text-end">
            <button class="btn btn-sm btn-primary" id="btnSavePackaging">
                <i class="bi bi-check-lg me-1"></i>{{ translations.save }}
            </button>
        </div>
    </div>

    {# ===== TILE 7: VIDANGES ===== #}
    {% set vid = recipe.vidanges %}
    <div class="card mb-3">
        <div class="card-header d-flex align-items-center gap-2">
            <span class="calc-tile-num">8</span>
            <span class="fw-semibold">{{ translations.vidanges_tile_title }}</span>
        </div>
        <div class="card-body">
            <div class="row g-3 align-items-start">
                <div class="col-12 col-md-5">
                    <label class="form-label">{{ translations.vidanges_carton_type }}</label>
                    <input type="text"
                           class="form-control"
                           id="vidCartonType"
                           maxlength="120"
                           value="{{ vid.carton_type is not null ? vid.carton_type : '' }}"
                           placeholder="{{ translations.vidanges_carton_type_placeholder }}">
                    <div class="invalid-feedback d-block small" id="errVidCartonType"></div>
                    <div class="form-text">{{ translations.vidanges_carton_type_hint }}</div>
                </div>

                <div class="col-12 col-md-4">
                    <label class="form-label">{{ translations.vidanges_deposit_per_carton }}</label>
                    <div class="input-group">
                        <input type="number"
                               step="0.01"
                               min="0"
                               class="form-control"
                               id="vidDepositPerCarton"
                               value="{{ vid.deposit_per_carton is not null ? vid.deposit_per_carton : '' }}">
                        <span class="input-group-text">{{ currency }}</span>
                    </div>
                    <div class="invalid-feedback d-block small" id="errVidDeposit"></div>
                    <div class="form-text">{{ translations.vidanges_deposit_hint }}</div>
                </div>
            </div>

            <div class="row g-3 mt-1">
                <div class="col-12 col-md-4">
                    <div class="border rounded p-3 bg-light h-100">
                        <div class="text-muted small text-uppercase">{{ translations.vidanges_deposit_per_packaging }}</div>
                        <div class="fw-bold fs-5 text-primary" id="vidDepositPerPackOut">
                            {% if vid.deposit_per_packaging is not null %}
                                {{ vid.deposit_per_packaging|number_format(2, '.', '') }} {{ currency }}
                            {% else %}<span class="text-muted">—</span>{% endif %}
                        </div>
                        <div class="form-text">{{ translations.vidanges_deposit_per_packaging_hint }}</div>
                    </div>
                </div>
                <div class="col-12 col-md-4">
                    <div class="border rounded p-3 bg-light h-100">
                        <div class="text-muted small text-uppercase">{{ translations.vidanges_deposit_per_portion }}</div>
                        <div class="fw-bold fs-5 text-primary" id="vidDepositPerPortionOut">
                            {% if vid.deposit_per_portion is not null %}
                                {{ vid.deposit_per_portion|number_format(2, '.', '') }} {{ currency }}
                            {% else %}<span class="text-muted">—</span>{% endif %}
                        </div>
                        <div class="form-text">{{ translations.vidanges_deposit_per_portion_hint }}</div>
                    </div>
                </div>
                <div class="col-12 col-md-4 d-flex align-items-center">
                    <div class="alert alert-info mb-0 py-2 px-3 small w-100">
                        <i class="bi bi-info-circle me-1"></i>{{ translations.vidanges_passthrough_note }}
                    </div>
                </div>
            </div>

            {% if recipe.sales_unit.packagings_per_carton is null or recipe.sales_unit.portions_per_packaging is null %}
                <div class="form-text mt-2 text-warning">
                    {{ translations.vidanges_missing_sales_unit }}
                </div>
            {% endif %}
        </div>
        <div class="card-footer text-end">
            <button class="btn btn-sm btn-primary" id="btnSaveVidanges">
                <i class="bi bi-check-lg me-1"></i>{{ translations.save }}
            </button>
        </div>
    </div>

    {# ===== TILE 8: P&L SUMMARY ===== #}
    {% set pnl = recipe.pnl %}
    {% set _pnl_ppp = pnl.portions_per_packaging %}
    {% set _pnl_ppc = pnl.packagings_per_carton %}
    <div class="card mb-3">
        <div class="card-header d-flex align-items-center gap-2">
            <span class="calc-tile-num">9</span>
            <span class="fw-semibold">{{ translations.pnl_tile_title }}</span>
            <div class="ms-auto">
                <div class="btn-group btn-group-sm" role="group" id="pnlViewToggleGroup">
                    <button type="button" class="btn btn-outline-primary" id="btnPnlViewCarton">
                        <i class="bi bi-box-seam me-1"></i>{{ translations.pnl_view_per_carton }}
                    </button>
                    <button type="button" class="btn btn-primary" id="btnPnlViewPortion">
                        <i class="bi bi-cup-straw me-1"></i>{{ translations.pnl_view_per_portion }}
                    </button>
                </div>
            </div>
        </div>
        <div class="card-body">
            <p class="text-muted small mb-3" id="pnlSuInfo">
                {{ translations.pnl_computed_per_carton }}:
                <strong>
                    {% if pnl.portions_per_carton is not null %}
                        {{ pnl.portions_per_carton }} {{ translations.pnl_portions }}
                    {% else %}
                        <span class="text-warning">{{ translations.pnl_missing_portions }}</span>
                    {% endif %}
                </strong>
            </p>

            {# ===== PANEL: PER CARTON ===== #}
            <div id="pnlCartonView" class="d-none">
                <div class="table-responsive mb-3">
                    <table class="table table-sm table-borderless mb-0" id="pnlCostTable">
                        <tbody>
                            <tr>
                                <td class="text-muted">{{ translations.pnl_raw_materials }}</td>
                                <td class="text-end fw-semibold" id="pnlRowMat">
                                    {% if pnl.raw_materials_per_carton is not null %}
                                        {{ pnl.raw_materials_per_carton|number_format(2, '.', '') }} {{ currency }}
                                    {% else %}<span class="text-muted">—</span>{% endif %}
                                </td>
                            </tr>
                            <tr>
                                <td class="text-muted">{{ translations.pnl_labor }}</td>
                                <td class="text-end fw-semibold" id="pnlRowLabor">
                                    {% if pnl.labor_per_carton is not null %}
                                        {{ pnl.labor_per_carton|number_format(2, '.', '') }} {{ currency }}
                                    {% else %}<span class="text-muted">—</span>{% endif %}
                                </td>
                            </tr>
                            <tr>
                                <td class="text-muted">{{ translations.pnl_overhead }}</td>
                                <td class="text-end fw-semibold" id="pnlRowOverhead">
                                    {% if pnl.overhead_per_carton is not null %}
                                        {{ pnl.overhead_per_carton|number_format(2, '.', '') }} {{ currency }}
                                    {% else %}<span class="text-muted">—</span>{% endif %}
                                </td>
                            </tr>
                            <tr>
                                <td class="text-muted">{{ translations.pnl_packaging }}</td>
                                <td class="text-end fw-semibold" id="pnlRowPackaging">
                                    {% if pnl.packaging_per_carton is not null %}
                                        {{ pnl.packaging_per_carton|number_format(2, '.', '') }} {{ currency }}
                                    {% else %}<span class="text-muted text-muted-sm">{{ translations.pnl_packaging_not_set }}</span>{% endif %}
                                </td>
                            </tr>
                            <tr class="table-light border-top">
                                <td class="fw-bold">{{ translations.pnl_total_cost_per_carton }}</td>
                                <td class="text-end fw-bold fs-6" id="pnlRowTotal">
                                    {% if pnl.total_cost_per_carton is not null %}
                                        {{ pnl.total_cost_per_carton|number_format(2, '.', '') }} {{ currency }}
                                    {% else %}<span class="text-muted">—</span>{% endif %}
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="alert alert-secondary py-2 px-3 small mb-3" id="pnlVidangesNote">
                    + <strong id="pnlVidVal">
                        {% if pnl.vidanges_per_carton is not null %}
                            {{ pnl.vidanges_per_carton|number_format(2, '.', '') }} {{ currency }}
                        {% else %}—{% endif %}
                    </strong>
                    {{ translations.pnl_vidanges_passthrough_carton }}
                </div>

                <div class="table-responsive mb-0">
                    <table class="table table-sm table-borderless mb-0">
                        <tbody>
                            <tr class="table-primary">
                                <td class="fw-bold">{{ translations.pnl_recommended_carton_price }}</td>
                                <td class="text-end fw-bold fs-5 text-primary" id="pnlRecommendedPrice">
                                    {% if pnl.recommended_carton_price is not null %}
                                        {{ pnl.recommended_carton_price|number_format(2, '.', '') }} {{ currency }}
                                    {% else %}<span class="text-muted fs-6">—</span>{% endif %}
                                </td>
                            </tr>
                            <tr>
                                <td class="text-muted small">
                                    {{ translations.pnl_per_portion_label }}
                                    <span class="text-muted" id="pnlMarginContext">
                                        {% if pnl.target_margin is not null %}({{ translations.pnl_margin }} {{ pnl.target_margin|number_format(2, '.', '') }}%){% endif %}
                                    </span>
                                </td>
                                <td class="text-end fw-semibold small text-muted" id="pnlPerPortionPrice">
                                    {% if pnl.per_portion_price is not null %}
                                        {{ pnl.per_portion_price|number_format(2, '.', '') }} {{ currency }}
                                    {% else %}<span class="text-muted">—</span>{% endif %}
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            {# ===== PANEL: PER PORTION ===== #}
            <div id="pnlPortionView">
                <div class="table-responsive mb-3">
                    <table class="table table-sm table-borderless mb-0">
                        <tbody>
                            <tr>
                                <td class="text-muted">{{ translations.pnl_raw_materials }}</td>
                                <td class="text-end fw-semibold" id="pnlPortRowMat">
                                    {% if pnl.raw_materials_per_portion is not null %}
                                        {{ pnl.raw_materials_per_portion|number_format(2, '.', '') }} {{ currency }}
                                    {% else %}<span class="text-muted">—</span>{% endif %}
                                </td>
                            </tr>
                            <tr>
                                <td class="text-muted">{{ translations.pnl_labor }}</td>
                                <td class="text-end fw-semibold" id="pnlPortRowLabor">
                                    {% if pnl.portions_per_carton and pnl.labor_per_carton is not null %}
                                        {{ (pnl.labor_per_carton / pnl.portions_per_carton)|number_format(2, '.', '') }} {{ currency }}
                                    {% else %}<span class="text-muted">—</span>{% endif %}
                                </td>
                            </tr>
                            <tr>
                                <td class="text-muted">{{ translations.pnl_overhead }}</td>
                                <td class="text-end fw-semibold" id="pnlPortRowOverhead">
                                    {% if pnl.portions_per_carton and pnl.overhead_per_carton is not null %}
                                        {{ (pnl.overhead_per_carton / pnl.portions_per_carton)|number_format(2, '.', '') }} {{ currency }}
                                    {% else %}<span class="text-muted">—</span>{% endif %}
                                </td>
                            </tr>
                            <tr>
                                <td class="text-muted">{{ translations.pnl_packaging }}</td>
                                <td class="text-end fw-semibold" id="pnlPortRowPackaging">
                                    {% if pnl.portions_per_carton and pnl.packaging_per_carton is not null %}
                                        {{ (pnl.packaging_per_carton / pnl.portions_per_carton)|number_format(2, '.', '') }} {{ currency }}
                                    {% else %}<span class="text-muted text-muted-sm">{{ translations.pnl_packaging_not_set }}</span>{% endif %}
                                </td>
                            </tr>
                            <tr class="table-light border-top">
                                <td class="fw-bold">{{ translations.pnl_total_cost }}</td>
                                <td class="text-end fw-bold fs-6" id="pnlPortRowTotal">
                                    {% if pnl.portions_per_carton and pnl.total_cost_per_carton is not null %}
                                        {{ (pnl.total_cost_per_carton / pnl.portions_per_carton)|number_format(2, '.', '') }} {{ currency }}
                                    {% else %}<span class="text-muted">—</span>{% endif %}
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="alert alert-secondary py-2 px-3 small mb-3">
                    + <strong id="pnlPortVidVal">
                        {% if pnl.portions_per_carton and pnl.vidanges_per_carton is not null %}
                            {{ (pnl.vidanges_per_carton / pnl.portions_per_carton)|number_format(2, '.', '') }} {{ currency }}
                        {% else %}—{% endif %}
                    </strong>
                    {{ translations.pnl_vidanges_passthrough }}
                </div>

                <div class="table-responsive mb-0">
                    <table class="table table-sm table-borderless mb-0">
                        <tbody>
                            <tr class="table-primary">
                                <td class="fw-bold">{{ translations.pnl_recommended_price }}</td>
                                <td class="text-end fw-bold fs-5 text-primary" id="pnlPortRecommendedPrice">
                                    {% if pnl.per_portion_price is not null %}
                                        {{ pnl.per_portion_price|number_format(2, '.', '') }} {{ currency }}
                                    {% else %}<span class="text-muted fs-6">—</span>{% endif %}
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            {# Margin slider — wspólny dla obu widoków #}
            <div class="mb-3 mt-3 pt-3 border-top">
                <label class="form-label d-flex justify-content-between align-items-center">
                    <span>{{ translations.pnl_target_margin }}</span>
                    <strong id="pnlMarginOut">
                        {% if pnl.target_margin is not null %}{{ pnl.target_margin|number_format(2, '.', '') }}%{% else %}—{% endif %}
                    </strong>
                </label>
                <input type="range"
                       class="form-range"
                       id="pnlMarginSlider"
                       min="0" max="80" step="1"
                       value="{{ pnl.target_margin is not null ? pnl.target_margin|round(0,'floor') : 0 }}">
                <div class="d-flex justify-content-between text-muted" style="font-size: 11px;">
                    <span>0%</span><span>20%</span><span>40%</span><span>60%</span><span>80%</span>
                </div>
                <div class="invalid-feedback d-block small" id="errPnlMargin"></div>
            </div>

            <div class="alert alert-warning py-2 px-3 small mt-0 mb-0" id="pnlIncompleteAlert"{% if pnl.is_complete %} style="display:none;"{% endif %}>
                <i class="bi bi-exclamation-triangle me-1"></i>{{ translations.pnl_incomplete_warning }}
                <ul class="mb-0 mt-1 ps-3" id="pnlIncompleteList">
                    {% if pnl.portions_per_packaging is null %}
                        <li data-key="portions">{{ translations.recipe_missing_sales_unit }}</li>
                    {% endif %}
                    {% if pnl.raw_materials_per_packaging is null %}
                        <li data-key="raw_materials">{{ translations.recipe_missing_raw_materials }}</li>
                    {% endif %}
                    {% if pnl.labor_per_packaging is null %}
                        <li data-key="labor">{{ translations.recipe_missing_labor }}</li>
                    {% endif %}
                    {% if pnl.overhead_per_packaging is null %}
                        <li data-key="overhead">{{ translations.recipe_missing_overhead }}</li>
                    {% endif %}
                </ul>
            </div>
        </div>
        <div class="card-footer text-end">
            <button class="btn btn-sm btn-primary" id="btnSavePnl">
                <i class="bi bi-check-lg me-1"></i>{{ translations.save }}
            </button>
        </div>
    </div>

    {# ===== MODAL: Quick-add raw material ===== #}
    {# ===== MODAL: Add raw material (full) ===== #}
    <div class="modal fade" id="modalQuickAddRm" tabindex="-1" aria-labelledby="modalQuickAddRmLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
