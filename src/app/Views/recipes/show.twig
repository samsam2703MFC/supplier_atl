    {# ===== AKCJE RECEPTURY ===== #}
    <div class="d-flex justify-content-between align-items-center mt-2 mb-5">        <div class="d-flex gap-2">
            {# {% if recipe.is_archived %}
                <button class="btn btn-outline-success btn-sm" id="btnRestoreRecipe">
                    <i class="bi bi-arrow-counterclockwise me-1"></i>{{ translations.restore }}
                </button>
            {% else %}
                <button class="btn btn-outline-warning btn-sm" id="btnArchiveRecipe">
                    <i class="bi bi-archive me-1"></i>{{ translations.archive }}
                </button>
            {% endif %} #}
